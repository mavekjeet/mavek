# Mavek website env vars — copy to .env.local and fill in real values
# ─────────────────────────────────────────────────────────────────────

# Web3Forms access key (for waitlist, contact, and exit-intent forms)
# Get yours free at: https://web3forms.com/
PUBLIC_WEB3FORMS_KEY=YOUR_WEB3FORMS_ACCESS_KEY_HERE

# Cal.com booking link (without the cal.com/ prefix)
# Example: if your booking page is cal.com/jeet/demo, set PUBLIC_CAL_LINK=jeet/demo
# Get yours free at: https://cal.com/signup
PUBLIC_CAL_LINK=YOUR_USERNAME/EVENT_SLUG
