---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <Nav />

  <section class="light not-found" style="padding-top: calc(var(--nav-height) + var(--space-3xl));">
    <div class="container">
      <div class="not-found__inner">
        <span class="not-found__code">404</span>
        <h1><em>Page not found.</em></h1>
        <p>Even our AI couldn't find this one. The page you're looking for doesn't exist or has been moved.</p>
        <div class="not-found__actions">
          <a href="/" class="btn btn--primary">Back to Home <span>&rarr;</span></a>
          <a href="/tools" class="btn btn--secondary">Try Our Free Tools</a>
        </div>
        <div class="not-found__links">
          <p class="not-found__hint">Looking for something specific?</p>
          <div class="not-found__grid">
            <a href="/for-agencies">For Agencies</a>
            <a href="/for-brands">For Brands</a>
            <a href="/pricing">Pricing</a>
            <a href="/blog">Blog</a>
            <a href="/compare">Compare</a>
            <a href="/contact">Contact</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .not-found {
    min-height: 70vh;
    display: flex;
    align-items: center;
  }

  .not-found__inner {
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }

  .not-found__code {
    font-family: var(--font-body);
    font-size: clamp(5rem, 12vw, 10rem);
    font-weight: 500;
    color: var(--gold-dark);
    opacity: 0.15;
    display: block;
    line-height: 1;
    margin-bottom: var(--space-sm);
  }

  .not-found__inner h1 {
    margin-bottom: var(--space-sm);
  }

  .not-found__inner > p {
    font-size: 1.1rem;
    margin-bottom: var(--space-lg);
  }

  .not-found__actions {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-xl);
    flex-wrap: wrap;
  }

  .not-found__hint {
    font-family: var(--font-body);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.4;
    margin-bottom: var(--space-sm);
  }

  .not-found__grid {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .not-found__grid a {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--ink);
    opacity: 0.6;
    transition: all 0.2s ease;
  }

  .not-found__grid a:hover {
    opacity: 1;
    color: var(--gold-dark);
  }
</style>
