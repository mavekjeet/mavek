---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import CTASection from '../../components/CTASection.astro';
import Footer from '../../components/Footer.astro';

const useCases = [
  {
    num: "01",
    title: "Google Ads Management",
    desc: "Autonomous campaign creation, bid optimization, and budget allocation that lowers CPA and maximizes ROAS around the clock.",
    href: "/use-cases/google-ads-management",
  },
  {
    num: "02",
    title: "SEO & Content Writing",
    desc: "Data-driven keyword research, content strategy, and long-form article writing grounded in your analytics — not generic keyword tools.",
    href: "/use-cases/seo-content-writing",
  },
  {
    num: "03",
    title: "Email Outreach & Lead Gen",
    desc: "Personalized outreach sequences, automated follow-ups, and response handling that fills your pipeline with qualified prospects.",
    href: "/use-cases/email-outreach",
  },
  {
    num: "04",
    title: "Marketing Analytics",
    desc: "Unified cross-channel dashboards, attribution modeling, and automated reporting that turns raw data into actionable insights.",
    href: "/use-cases/marketing-analytics",
  },
];
---

<Layout title="Use Cases" description="Discover how Mavek automates Google Ads, SEO content, email outreach, and marketing analytics — one platform for every marketing function.">
  <Nav />

  <section class="section light hero-section">
    <div class="container">
      <div class="hero__inner reveal">
        <span class="sec-label">USE CASES</span>
        <h1>One platform.<br />Every marketing function.</h1>
        <p class="hero__subtitle">From paid ads to organic content, outreach to analytics — Mavek handles the full marketing stack autonomously so you can focus on strategy.</p>
      </div>
    </div>
  </section>

  <section class="section dark">
    <div class="container">
      <div class="grid-2">
        {useCases.map((uc, i) => (
          <a href={uc.href} class="card card--dark usecase-card reveal" style={`transition-delay: ${i * 0.1}s`}>
            <span class="usecase-card__num">{uc.num}</span>
            <h3>{uc.title}</h3>
            <p>{uc.desc}</p>
            <span class="usecase-card__link">Learn more &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section light">
    <div class="container">
      <div class="why__inner reveal">
        <span class="sec-label">Why One Platform</span>
        <h2>Fragmented tools create <em>fragmented results</em></h2>
        <p>Most marketing stacks are duct-taped together — separate tools for ads, SEO, email, and analytics that never share context. Mavek unifies everything under one AI brain, so every channel learns from every other channel.</p>
        <div class="why__grid grid-3">
          <div class="card reveal">
            <h4>Shared Intelligence</h4>
            <p style="font-size: 0.9rem; margin-top: 0.5rem;">Ad performance informs content topics. Content engagement shapes outreach messaging. Everything connects.</p>
          </div>
          <div class="card reveal" style="transition-delay: 0.1s">
            <h4>One Dashboard</h4>
            <p style="font-size: 0.9rem; margin-top: 0.5rem;">No more switching between eight tabs. See every channel, every metric, every insight in a single view.</p>
          </div>
          <div class="card reveal" style="transition-delay: 0.2s">
            <h4>Compounding Returns</h4>
            <p style="font-size: 0.9rem; margin-top: 0.5rem;">The more channels Mavek runs, the smarter each one gets. Cross-channel data compounds over time.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="Ready to consolidate your marketing stack?"
    subtitle="One platform. Every function. 10x more efficient."
  />

  <Footer />
</Layout>

<style>
  .hero-section {
    padding-top: calc(var(--nav-height) + var(--space-3xl));
    text-align: center;
  }

  .hero__inner {
    max-width: 700px;
    margin: 0 auto;
  }

  .hero__inner h1 {
    margin-top: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .hero__subtitle {
    font-size: 1.15rem;
    max-width: 560px;
    margin: 0 auto;
  }

  .usecase-card {
    display: block;
    text-decoration: none;
    position: relative;
  }

  .usecase-card__num {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--gold-mid);
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: var(--space-sm);
  }

  .usecase-card h3 {
    margin-bottom: var(--space-xs);
  }

  .usecase-card__link {
    display: inline-block;
    margin-top: var(--space-md);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--gold-mid);
    transition: gap var(--duration) var(--ease);
  }

  .usecase-card:hover .usecase-card__link {
    text-decoration: underline;
  }

  .why__inner {
    text-align: center;
  }

  .why__inner h2 {
    margin-top: var(--space-xs);
    margin-bottom: var(--space-sm);
  }

  .why__inner > p {
    max-width: 600px;
    margin: 0 auto var(--space-xl);
  }

  .why__grid {
    text-align: left;
  }
</style>
