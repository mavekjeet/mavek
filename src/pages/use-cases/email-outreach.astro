---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import CTASection from '../../components/CTASection.astro';
import Footer from '../../components/Footer.astro';

const capabilities = [
  { title: "Prospect Identification", desc: "Mavek finds and verifies prospects that match your ICP — using firmographic, technographic, and intent signals, not purchased lists." },
  { title: "Personalized Sequences", desc: "Every email is tailored to the prospect's role, company, and pain points. No mail-merge tokens that scream automation." },
  { title: "Follow-Up Automation", desc: "Multi-touch sequences that adapt based on engagement. Mavek knows when to nudge, when to pivot, and when to stop." },
  { title: "Response Handling", desc: "Positive replies are flagged and routed instantly. Objections are categorized. Out-of-office replies are handled automatically." },
  { title: "CRM Integration", desc: "Every interaction syncs to your CRM in real time. Deals move through your pipeline without manual data entry." },
  { title: "Deliverability Management", desc: "Domain warming, sending limits, and bounce monitoring to keep your sender reputation healthy and inboxes reachable." },
];

const personalizationPoints = [
  { title: "ICP-Driven Targeting", desc: "Define your ideal customer profile once. Mavek finds prospects that match — and skips everyone who doesn't." },
  { title: "Research-Based Messaging", desc: "Each email references the prospect's company, recent activity, or industry context. Personalization goes beyond {first_name}." },
  { title: "Adaptive Sequences", desc: "If a prospect engages but doesn't reply, the next email shifts angle. Mavek tests messaging variants and doubles down on what works." },
];
---

<Layout title="Automated Email Outreach & Lead Gen" description="AI-powered email outreach that finds ideal prospects, writes personalized sequences, and fills your pipeline — without templates or spam.">
  <Nav />

  <section class="section light hero-section">
    <div class="container">
      <div class="hero__inner reveal">
        <span class="sec-label">USE CASE</span>
        <h1>Automated Email Outreach & Lead Gen</h1>
        <p class="hero__subtitle">Fill your pipeline with qualified prospects through personalized outreach sequences that run autonomously — no templates, no spam, no manual work.</p>
        <div class="hero__actions">
          <a href="/contact" class="btn btn--primary">Get Started <span>&rarr;</span></a>
          <a href="/use-cases" class="btn btn--secondary">All Use Cases</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section dark">
    <div class="container">
      <div class="section-header reveal">
        <span class="sec-label">Capabilities</span>
        <h2>What Mavek does for <em>outreach</em></h2>
      </div>
      <div class="grid-3">
        {capabilities.map((c, i) => (
          <div class="card card--dark reveal" style={`transition-delay: ${i * 0.08}s`}>
            <h4>{c.title}</h4>
            <p style="font-size: 0.9rem; margin-top: 0.5rem;">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section light">
    <div class="container">
      <div class="section-header reveal">
        <span class="sec-label">Personalization</span>
        <h2>How personalization <em>actually works</em></h2>
        <p class="section-header__sub">Most outreach tools promise personalization but deliver mail merge. Mavek takes a different approach — using your ICP data and real prospect research to craft emails that get replies.</p>
      </div>
      <div class="grid-3">
        {personalizationPoints.map((p, i) => (
          <div class="card reveal" style={`transition-delay: ${i * 0.1}s`}>
            <h4>{p.title}</h4>
            <p style="font-size: 0.9rem; margin-top: 0.5rem;">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section dark">
    <div class="container">
      <div class="section-header reveal">
        <span class="sec-label">How It Works</span>
        <h2>From ICP to <em>pipeline</em> in three steps</h2>
      </div>
      <div class="steps">
        <div class="step reveal">
          <span class="step__num">01</span>
          <div class="step__content">
            <h3>Define your ICP</h3>
            <p>Tell Mavek who you sell to — industry, company size, role, tech stack, pain points. The more specific, the better the targeting.</p>
          </div>
        </div>
        <div class="step reveal" style="transition-delay: 0.1s">
          <span class="step__num">02</span>
          <div class="step__content">
            <h3>Mavek builds and sends</h3>
            <p>Prospects are found, verified, and enrolled in personalized sequences. Each email is crafted around their specific context.</p>
          </div>
        </div>
        <div class="step reveal" style="transition-delay: 0.2s">
          <span class="step__num">03</span>
          <div class="step__content">
            <h3>Replies flow to your inbox</h3>
            <p>Interested prospects are flagged and routed. Mavek handles the noise — bounces, out-of-office, and unsubscribes — so you only see real opportunities.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section light">
    <div class="container">
      <div class="no-spam reveal">
        <span class="sec-label">The Mavek Difference</span>
        <h2>Outreach that doesn't feel like <em>outreach</em></h2>
        <div class="grid-2" style="margin-top: var(--space-xl); text-align: left;">
          <div class="card reveal">
            <h4>What we don't do</h4>
            <ul class="diff-list diff-list--old">
              <li>Blast purchased lists with generic templates</li>
              <li>Send hundreds of identical emails per day</li>
              <li>Ignore deliverability and sender reputation</li>
              <li>Use aggressive, pushy sales language</li>
            </ul>
          </div>
          <div class="card reveal" style="transition-delay: 0.1s; border-color: var(--gold-mid);">
            <h4>What we do</h4>
            <ul class="diff-list diff-list--new">
              <li>Target verified prospects matching your ICP</li>
              <li>Send thoughtful, researched emails at safe volumes</li>
              <li>Protect your domain with proper warming and limits</li>
              <li>Write conversationally, like a real human would</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="Fill your pipeline on autopilot."
    subtitle="Personalized outreach. Qualified prospects. Zero manual work."
  />

  <Footer />
</Layout>

<style>
  .hero-section {
    padding-top: calc(var(--nav-height) + var(--space-3xl));
    text-align: center;
  }

  .hero__inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .hero__inner h1 {
    margin-top: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .hero__subtitle {
    font-size: 1.15rem;
    max-width: 600px;
    margin: 0 auto var(--space-lg);
  }

  .hero__actions {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .section-header h2 {
    margin-top: var(--space-xs);
  }

  .section-header__sub {
    max-width: 600px;
    margin: var(--space-sm) auto 0;
  }

  .steps {
    max-width: 700px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .step {
    display: flex;
    gap: var(--space-lg);
    align-items: flex-start;
  }

  .step__num {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--gold-mid);
    letter-spacing: 0.1em;
    flex-shrink: 0;
    padding-top: 0.3rem;
  }

  .step__content h3 {
    margin-bottom: var(--space-xs);
  }

  .no-spam {
    text-align: center;
  }

  .no-spam h2 {
    margin-top: var(--space-xs);
  }

  .diff-list {
    list-style: none;
    margin-top: var(--space-sm);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .diff-list li {
    font-size: 0.9rem;
    padding-left: 1.5rem;
    position: relative;
  }

  .diff-list--old li::before {
    content: "\2717";
    position: absolute;
    left: 0;
    color: var(--muted);
  }

  .diff-list--new li::before {
    content: "\2713";
    position: absolute;
    left: 0;
    color: var(--gold-dark);
  }

  @media (max-width: 600px) {
    .hero__actions { flex-direction: column; align-items: center; }
    .step { flex-direction: column; gap: var(--space-sm); }
  }
</style>
