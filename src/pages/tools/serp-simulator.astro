---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import CTASection from '../../components/CTASection.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Google SERP Simulator" description="Simulate a full Google search results page with multiple listings. See how your page compares against competitors in real search results.">
  <Nav />

  <section class="light serpsim-hero" style="padding-top: calc(var(--nav-height) + var(--space-3xl));">
    <div class="container">
      <a href="/tools" class="back-link reveal">&larr; Back to Tools</a>
      <div class="serpsim-hero__content reveal">
        <span class="sec-label">Google SERP Simulator</span>
        <h1>See your listing <em>in context</em>.</h1>
        <p class="serpsim-hero__lead">Build a mock Google results page with up to 10 listings. See how your title and description stack up against the competition before you publish.</p>
      </div>
    </div>
  </section>

  <section class="light serpsim-tool-section" style="padding-top: 0;">
    <div class="container">
      <div class="serpsim-tool reveal">
        <div class="serpsim-search-input">
          <label class="serpsim-label" for="searchQuery">Search Query</label>
          <input type="text" id="searchQuery" class="serpsim-input" placeholder="e.g. best project management tools" />
        </div>

        <div class="serpsim-entries" id="serpEntries">
          <div class="serpsim-entry" data-index="0">
            <div class="serpsim-entry__header">
              <span class="serpsim-entry__num">Result 1</span>
              <label class="serpsim-highlight-label">
                <input type="checkbox" class="highlight-check" checked />
                <span>Highlight (your listing)</span>
              </label>
              <button class="serpsim-entry__remove" title="Remove">&times;</button>
            </div>
            <div class="serpsim-entry__fields">
              <div class="serpsim-field">
                <label class="serpsim-field__label">Page Title</label>
                <input type="text" class="serpsim-field-input title-input" placeholder="Your Page Title | Brand" maxlength="120" />
                <span class="serpsim-charcount title-count">0 / 60</span>
              </div>
              <div class="serpsim-field">
                <label class="serpsim-field__label">URL</label>
                <input type="text" class="serpsim-field-input url-input" placeholder="https://example.com/page" />
              </div>
              <div class="serpsim-field">
                <label class="serpsim-field__label">Meta Description</label>
                <textarea class="serpsim-field-input desc-input" placeholder="Your meta description goes here..." rows="2" maxlength="320"></textarea>
                <span class="serpsim-charcount desc-count">0 / 160</span>
              </div>
            </div>
          </div>
        </div>

        <div class="serpsim-add-wrap">
          <button class="btn btn--secondary" id="addEntryBtn">+ Add Result</button>
        </div>

        <button class="btn btn--primary serpsim-generate" id="generateBtn">Generate SERP Preview <span>&rarr;</span></button>

        <div class="serpsim-preview-section" id="previewSection" style="display: none;">
          <div class="serpsim-preview">
            <div class="serpsim-google-bar">
              <div class="serpsim-google-logo">
                <span style="color:#4285F4;">G</span><span style="color:#EA4335;">o</span><span style="color:#FBBC05;">o</span><span style="color:#4285F4;">g</span><span style="color:#34A853;">l</span><span style="color:#EA4335;">e</span>
              </div>
              <div class="serpsim-google-search">
                <span id="previewQuery"></span>
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="9" cy="9" r="6" stroke="#9aa0a6" stroke-width="1.5"/><path d="M13 13l4 4" stroke="#9aa0a6" stroke-width="1.5" stroke-linecap="round"/></svg>
              </div>
              <div class="serpsim-google-tabs">
                <span class="serpsim-google-tab active">All</span>
                <span class="serpsim-google-tab">Images</span>
                <span class="serpsim-google-tab">Videos</span>
                <span class="serpsim-google-tab">News</span>
                <span class="serpsim-google-tab">Maps</span>
              </div>
            </div>
            <div class="serpsim-google-info" id="resultCount"></div>
            <div class="serpsim-google-results" id="serpResults"></div>
          </div>
        </div>

        <div class="serpsim-nudge" id="serpNudge" style="display: none;">
          <div class="card">
            <span class="serpsim-nudge__label">Mavek Tip</span>
            <p class="serpsim-nudge__text">Your title is the first thing users see in search results. Make it compelling and keep it under 60 characters. Highlighted results should immediately stand out -- if they don't, rework the title.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="dark">
    <div class="container">
      <div class="serpsim-tips reveal">
        <div class="serpsim-tips__header">
          <span class="sec-label">SERP Tips</span>
          <h2>How to stand out <em>in search results</em></h2>
        </div>
        <div class="grid-3" style="margin-top: var(--space-xl);">
          <div class="card card--dark" style="border-radius: 10px;">
            <h4>Front-load your keyword</h4>
            <p>Put your main keyword at the start of the title. Users scan the left side first, and Google boldens matching terms.</p>
          </div>
          <div class="card card--dark" style="border-radius: 10px;">
            <h4>Write compelling descriptions</h4>
            <p>Your meta description is your ad copy in search. Include a clear value proposition and a reason to click your result over others.</p>
          </div>
          <div class="card card--dark" style="border-radius: 10px;">
            <h4>Use clean, readable URLs</h4>
            <p>Short URLs with real words outperform long parameter-filled ones. Users judge credibility partly by how clean the URL looks.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="Let Mavek optimize your search presence"
    subtitle="From titles to descriptions to structured data -- our AI crafts every search element for maximum click-through rates."
    primaryCta="Get Started"
    primaryHref="/contact"
    secondaryCta="See How It Works"
    secondaryHref="/how-it-works"
  />

  <Footer />
</Layout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gold-dark);
    margin-bottom: var(--space-lg);
    transition: gap 0.3s var(--ease);
  }

  .back-link:hover {
    gap: 0.8rem;
  }

  .serpsim-hero__content {
    max-width: 640px;
  }

  .serpsim-hero__content h1 {
    margin: var(--space-xs) 0 var(--space-md);
  }

  .serpsim-hero__lead {
    font-size: 1.1rem;
  }

  .serpsim-tool {
    max-width: 860px;
    margin: 0 auto;
  }

  .serpsim-label {
    display: block;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    margin-bottom: var(--space-xs);
  }

  .serpsim-input {
    width: 100%;
    padding: 0.875rem 1.25rem;
    font-family: var(--font-body);
    font-size: 1rem;
    background: var(--parchment-dark);
    border: 1px solid rgba(26, 26, 24, 0.1);
    color: var(--ink);
    outline: none;
    transition: border-color 0.2s ease;
    box-sizing: border-box;
  }

  .serpsim-input:focus {
    border-color: var(--gold-dark);
  }

  .serpsim-search-input {
    margin-bottom: var(--space-lg);
  }

  /* Entries */
  .serpsim-entry {
    background: var(--parchment-dark);
    border: 1px solid rgba(26, 26, 24, 0.06);
    border-radius: 10px;
    padding: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .serpsim-entry__header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .serpsim-entry__num {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.4;
  }

  .serpsim-highlight-label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.78rem;
    cursor: pointer;
    margin-left: auto;
  }

  .serpsim-highlight-label input {
    accent-color: var(--gold-dark);
  }

  .serpsim-entry__remove {
    background: none;
    border: none;
    font-size: 1.4rem;
    color: var(--ink);
    opacity: 0.3;
    cursor: pointer;
    padding: 0.2rem 0.4rem;
    line-height: 1;
    transition: opacity 0.2s ease;
  }

  .serpsim-entry__remove:hover {
    opacity: 0.8;
    color: #CC4030;
  }

  .serpsim-entry__fields {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .serpsim-field {
    position: relative;
  }

  .serpsim-field__label {
    display: block;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 500;
    margin-bottom: 0.3rem;
    opacity: 0.6;
  }

  .serpsim-field-input {
    width: 100%;
    padding: 0.5rem 0.75rem;
    font-family: var(--font-body);
    font-size: 0.88rem;
    background: #fff;
    border: 1px solid rgba(26, 26, 24, 0.1);
    color: var(--ink);
    outline: none;
    box-sizing: border-box;
    resize: none;
  }

  .serpsim-field-input:focus {
    border-color: var(--gold-dark);
  }

  .serpsim-charcount {
    position: absolute;
    right: 0.5rem;
    bottom: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.65rem;
    opacity: 0.3;
  }

  .serpsim-charcount.over {
    color: #CC4030;
    opacity: 0.8;
  }

  .serpsim-add-wrap {
    margin: var(--space-md) 0 var(--space-lg);
  }

  .serpsim-generate {
    margin-bottom: var(--space-xl);
  }

  /* SERP Preview */
  .serpsim-preview {
    background: #fff;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: var(--space-lg);
  }

  .serpsim-google-bar {
    padding: 1rem 1.5rem 0;
    border-bottom: 1px solid #ebebeb;
  }

  .serpsim-google-logo {
    font-family: 'Arial', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .serpsim-google-search {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #fff;
    border: 1px solid #dfe1e5;
    border-radius: 24px;
    padding: 0.6rem 1rem;
    margin-bottom: 0.75rem;
    font-size: 0.9rem;
    color: #202124;
  }

  .serpsim-google-tabs {
    display: flex;
    gap: 0;
  }

  .serpsim-google-tab {
    padding: 0.6rem 1rem;
    font-family: Arial, sans-serif;
    font-size: 0.8rem;
    color: #70757a;
    cursor: default;
    border-bottom: 3px solid transparent;
  }

  .serpsim-google-tab.active {
    color: #1a73e8;
    border-bottom-color: #1a73e8;
    font-weight: 500;
  }

  .serpsim-google-info {
    padding: 0.5rem 1.5rem;
    font-family: Arial, sans-serif;
    font-size: 0.78rem;
    color: #70757a;
  }

  .serpsim-google-results {
    padding: 0 1.5rem 1.5rem;
  }

  .serpsim-result {
    padding: 1rem 0;
    max-width: 600px;
  }

  .serpsim-result + .serpsim-result {
    border-top: 1px solid #f0f0f0;
  }

  .serpsim-result.highlighted {
    background: rgba(66, 133, 244, 0.04);
    margin: 0 -1rem;
    padding: 1rem;
    border-radius: 8px;
    border: 1px solid rgba(66, 133, 244, 0.15);
  }

  .serpsim-result__url {
    font-family: Arial, sans-serif;
    font-size: 0.78rem;
    color: #202124;
    margin-bottom: 0.15rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .serpsim-result__favicon {
    width: 18px;
    height: 18px;
    background: #f0f0f0;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6rem;
    color: #70757a;
    font-weight: 700;
  }

  .serpsim-result__breadcrumb {
    color: #4d5156;
    font-size: 0.72rem;
  }

  .serpsim-result__title {
    font-family: Arial, sans-serif;
    font-size: 1.15rem;
    color: #1a0dab;
    line-height: 1.3;
    margin-bottom: 0.25rem;
    cursor: default;
  }

  .serpsim-result__desc {
    font-family: Arial, sans-serif;
    font-size: 0.84rem;
    color: #4d5156;
    line-height: 1.45;
  }

  /* Nudge */
  .serpsim-nudge__label {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gold-dark);
    margin-bottom: var(--space-sm);
  }

  .serpsim-nudge__text {
    font-size: 0.95rem;
    line-height: 1.6;
  }

  /* Tips */
  .serpsim-tips__header {
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .serpsim-tips__header h2 {
    margin-top: var(--space-xs);
  }

  @media (max-width: 600px) {
    .serpsim-entry__header {
      flex-wrap: wrap;
    }

    .serpsim-google-tabs {
      overflow-x: auto;
    }

    .serpsim-google-bar {
      padding: 0.75rem 1rem 0;
    }

    .serpsim-google-results {
      padding: 0 1rem 1rem;
    }
  }
</style>

<script is:inline>
  var serpEntries = document.getElementById('serpEntries');
  var addEntryBtn = document.getElementById('addEntryBtn');
  var generateBtn = document.getElementById('generateBtn');
  var previewSection = document.getElementById('previewSection');
  var serpResults = document.getElementById('serpResults');
  var previewQuery = document.getElementById('previewQuery');
  var resultCount = document.getElementById('resultCount');
  var serpNudge = document.getElementById('serpNudge');
  var entryCount = 1;

  // Character counters
  serpEntries.addEventListener('input', function(e) {
    var entry = e.target.closest('.serpsim-entry');
    if (!entry) return;

    if (e.target.classList.contains('title-input')) {
      var counter = entry.querySelector('.title-count');
      var len = e.target.value.length;
      counter.textContent = len + ' / 60';
      counter.classList.toggle('over', len > 60);
    }

    if (e.target.classList.contains('desc-input')) {
      var counter = entry.querySelector('.desc-count');
      var len = e.target.value.length;
      counter.textContent = len + ' / 160';
      counter.classList.toggle('over', len > 160);
    }
  });

  function getEntryTemplate(num) {
    return '<div class="serpsim-entry__header">' +
      '<span class="serpsim-entry__num">Result ' + num + '</span>' +
      '<label class="serpsim-highlight-label">' +
      '<input type="checkbox" class="highlight-check" />' +
      '<span>Highlight (your listing)</span></label>' +
      '<button class="serpsim-entry__remove" title="Remove">&times;</button>' +
      '</div>' +
      '<div class="serpsim-entry__fields">' +
      '<div class="serpsim-field"><label class="serpsim-field__label">Page Title</label>' +
      '<input type="text" class="serpsim-field-input title-input" placeholder="Competitor Page Title | Brand" maxlength="120" />' +
      '<span class="serpsim-charcount title-count">0 / 60</span></div>' +
      '<div class="serpsim-field"><label class="serpsim-field__label">URL</label>' +
      '<input type="text" class="serpsim-field-input url-input" placeholder="https://competitor.com/page" /></div>' +
      '<div class="serpsim-field"><label class="serpsim-field__label">Meta Description</label>' +
      '<textarea class="serpsim-field-input desc-input" placeholder="Competitor meta description..." rows="2" maxlength="320"></textarea>' +
      '<span class="serpsim-charcount desc-count">0 / 160</span></div>' +
      '</div>';
  }

  addEntryBtn.addEventListener('click', function() {
    var entries = serpEntries.querySelectorAll('.serpsim-entry');
    if (entries.length >= 10) return;
    entryCount++;
    var entry = document.createElement('div');
    entry.className = 'serpsim-entry';
    entry.innerHTML = getEntryTemplate(entryCount);
    serpEntries.appendChild(entry);
  });

  // Remove entry
  serpEntries.addEventListener('click', function(e) {
    if (e.target.classList.contains('serpsim-entry__remove')) {
      var entries = serpEntries.querySelectorAll('.serpsim-entry');
      if (entries.length > 1) {
        e.target.closest('.serpsim-entry').remove();
        // Renumber
        serpEntries.querySelectorAll('.serpsim-entry').forEach(function(entry, i) {
          entry.querySelector('.serpsim-entry__num').textContent = 'Result ' + (i + 1);
        });
      }
    }
  });

  function truncate(str, max) {
    if (str.length <= max) return str;
    return str.substring(0, max) + '...';
  }

  function escapeHtml(str) {
    var div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function formatUrl(url) {
    return url.replace(/^https?:\/\//, '').replace(/\/$/, '');
  }

  function generatePreview() {
    var query = document.getElementById('searchQuery').value.trim() || 'search query';
    previewQuery.textContent = query;

    var entries = serpEntries.querySelectorAll('.serpsim-entry');
    var html = '';
    var count = 0;

    entries.forEach(function(entry) {
      var title = entry.querySelector('.title-input').value.trim();
      var url = entry.querySelector('.url-input').value.trim();
      var desc = entry.querySelector('.desc-input').value.trim();
      var isHighlighted = entry.querySelector('.highlight-check').checked;

      if (!title && !url && !desc) return;
      count++;

      var displayTitle = truncate(title || 'Untitled Page', 60);
      var displayDesc = truncate(desc || 'No description provided.', 160);
      var displayUrl = url || 'https://example.com';
      var domain = formatUrl(displayUrl).split('/')[0];
      var letter = domain.charAt(0).toUpperCase();

      html += '<div class="serpsim-result' + (isHighlighted ? ' highlighted' : '') + '">';
      html += '<div class="serpsim-result__url">';
      html += '<span class="serpsim-result__favicon">' + escapeHtml(letter) + '</span>';
      html += '<div><div>' + escapeHtml(domain) + '</div><div class="serpsim-result__breadcrumb">' + escapeHtml(formatUrl(displayUrl)) + '</div></div>';
      html += '</div>';
      html += '<div class="serpsim-result__title">' + escapeHtml(displayTitle) + '</div>';
      html += '<div class="serpsim-result__desc">' + escapeHtml(displayDesc) + '</div>';
      html += '</div>';
    });

    if (count === 0) return;

    resultCount.textContent = 'About ' + (count * 12400).toLocaleString() + ' results (0.42 seconds)';
    serpResults.innerHTML = html;
    previewSection.style.display = 'block';
    serpNudge.style.display = 'block';
    previewSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  generateBtn.addEventListener('click', generatePreview);
</script>
