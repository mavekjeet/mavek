---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import TeamCredibility from '../components/TeamCredibility.astro';
import ProblemCards from '../components/ProblemCards.astro';
import SolutionIntro from '../components/SolutionEquation.astro';
import HowItWorks from '../components/HowItWorks.astro';
import UseCases from '../components/UseCases.astro';
import AgentSwarm from '../components/AgentSwarm.astro';
import Differentiator from '../components/Differentiator.astro';
import CTASection from '../components/CTASection.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Your AI Marketing Team | Mavek" schema={[
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Mavek",
    "url": "https://mavek.ai",
    "description": "Your AI marketing team. Expert AI agents and real humans, powered by your data — handling your ads, content, SEO, and analytics end-to-end.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://mavek.ai/blog?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Mavek",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "url": "https://mavek.ai",
    "description": "AI marketing team for founders and lean marketing teams at SMBs. Expert AI agents and real humans handle your ads, content, SEO, and analytics end-to-end.",
    "offers": {
      "@type": "Offer",
      "price": "299",
      "priceCurrency": "USD",
      "priceValidUntil": "2027-12-31"
    }
  }
]}>
  <Nav />

  <Hero
    eyebrow="AI AGENTS + REAL HUMANS"
    title="Your AI marketing <em>team.</em>"
    subtitle="For founders and lean teams who need full-stack marketing but can't hire a department. Expert AI agents and real humans handle your ads, content, SEO, and analytics end-to-end. You just approve."
    primaryCta="Talk to the Team"
    primaryHref="/contact"
    secondaryCta="See How It Works"
    secondaryHref="/how-it-works"
  />

  <TeamCredibility />

  <ProblemCards dark={true} />

  <SolutionIntro />

  <HowItWorks />

  <UseCases dark={true} />

  <AgentSwarm />

  <Differentiator />

  <CTASection
    title="Your marketing doesn't need more tools. <em>It needs Mavek.</em>"
    subtitle="Expert AI agents. Your real data. Real humans. Full execution."
    primaryCta="Talk to the Team"
    primaryHref="/contact"
    secondaryCta="See Pricing"
    secondaryHref="/pricing"
  />

  <Footer />
</Layout>
