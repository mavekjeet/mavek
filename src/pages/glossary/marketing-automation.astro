---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import CTASection from '../../components/CTASection.astro';
import Footer from '../../components/Footer.astro';

const components = [
  {
    title: "Email Automation",
    description: "Trigger-based email sequences that nurture leads, onboard customers, and re-engage dormant contacts without manual sends.",
  },
  {
    title: "Lead Scoring",
    description: "Assign numerical values to leads based on behavior and demographics so sales teams focus on the highest-intent prospects.",
  },
  {
    title: "Campaign Management",
    description: "Plan, launch, and coordinate multi-channel campaigns from a single workflow instead of juggling six different tools.",
  },
  {
    title: "Analytics & Reporting",
    description: "Unified dashboards that pull data from every channel into one view, making it easy to spot what is working and what is not.",
  },
  {
    title: "CRM Integration",
    description: "Sync marketing activity with your CRM so every touchpoint is tracked and sales has full context before the first call.",
  },
];

const relatedTerms = [
  { term: "Full-Funnel Marketing", slug: "full-funnel-marketing" },
  { term: "ROAS (Return on Ad Spend)", slug: "roas" },
  { term: "Customer Acquisition Cost (CAC)", slug: "customer-acquisition-cost" },
  { term: "Marketing Attribution", slug: "marketing-attribution" },
];
---

<Layout title="What Is Marketing Automation? Definition & Guide" description="Marketing automation uses software to handle repetitive marketing tasks at scale. Learn what it is, its key components, and how Mavek goes beyond automation to autonomous execution.">
  <Nav />

  <article class="section light glossary-article" style="padding-top: calc(var(--nav-height) + var(--space-3xl));">
    <div class="container">
      <div class="article__header reveal">
        <a href="/glossary" class="article__back">&larr; Back to Glossary</a>
        <span class="sec-label">Glossary</span>
        <h1>Marketing Automation</h1>
        <p class="article__lead">Technology that automates repetitive marketing tasks -- email sequences, social scheduling, ad management, and lead nurturing -- so teams can focus on strategy instead of busywork.</p>
      </div>

      <div class="article__body reveal">
        <h2>What is <em>marketing automation</em>?</h2>
        <p>Marketing automation refers to software platforms that manage routine marketing processes across multiple channels with minimal human intervention. Instead of manually sending every email, scheduling every social post, or adjusting every ad bid, automation tools handle these tasks based on predefined rules and triggers.</p>
        <p>At its simplest, marketing automation is a set of if-then workflows. If a visitor downloads a whitepaper, then send a follow-up email in two days. If a lead visits the pricing page three times, then notify sales. These rules run in the background while your team focuses on creative and strategic work.</p>
        <p>The category has grown well beyond email. Modern marketing automation platforms span paid ads, content distribution, social media, SMS, chatbots, and reporting -- though most still require significant setup and ongoing oversight to deliver results.</p>
      </div>
    </div>
  </article>

  <section class="section light components-section">
    <div class="container">
      <div class="article__body reveal">
        <h2>Key components of <em>marketing automation</em></h2>
        <p>Most marketing automation platforms share a common set of capabilities, though the depth of each varies widely.</p>
      </div>
      <div class="grid-3 components-grid">
        {components.map((item, i) => (
          <div class="card component-card reveal" style={`transition-delay: ${i * 0.06}s`}>
            <h4>{item.title}</h4>
            <p>{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section dark mavek-section">
    <div class="container">
      <div class="article__body reveal">
        <span class="sec-label">How Mavek Approaches It</span>
        <h2>Beyond automation to <em>autonomous execution</em></h2>
        <p>Traditional marketing automation still requires a human to build the workflows, write the copy, choose the audiences, and interpret the data. You automate the delivery, but the thinking stays manual.</p>
        <p>Mavek operates differently. Instead of handing you a blank canvas of triggers and rules, Mavek acts as an autonomous marketing system. It learns your brand, your audience, and your goals -- then plans, creates, launches, and optimizes campaigns across channels on its own.</p>
        <p>The difference is the gap between a dishwasher and a personal chef. A dishwasher automates one task. A chef understands the whole picture and executes end to end. Mavek is the chef: it handles strategy, content creation, ad buying, email sequencing, and performance analysis as a single coordinated system, with human approval gates at every step.</p>
      </div>
    </div>
  </section>

  <section class="section light related-section">
    <div class="container">
      <div class="article__body reveal">
        <h2>Related terms</h2>
        <div class="related-grid">
          {relatedTerms.map(item => (
            <a href={`/glossary/${item.slug}`} class="related-link">
              {item.term} <span>&rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="See autonomous marketing in action"
    subtitle="Mavek goes beyond automation. One platform, every channel, zero busywork."
    primaryCta="Get Started"
    primaryHref="/contact"
    secondaryCta="How It Works"
    secondaryHref="/how-it-works"
  />

  <Footer />
</Layout>

<style>
  .article__header {
    max-width: 720px;
    margin-bottom: var(--space-xl);
  }

  .article__back {
    font-family: var(--font-body);
    font-size: 0.75rem;
    opacity: 0.5;
    margin-bottom: var(--space-md);
    display: inline-block;
    transition: opacity 0.2s ease;
  }

  .article__back:hover {
    opacity: 1;
    color: var(--gold-dark);
  }

  .article__header .sec-label {
    display: block;
    margin-bottom: var(--space-xs);
  }

  .article__header h1 {
    margin-bottom: var(--space-md);
    font-size: clamp(2rem, 4.5vw, 3.2rem);
  }

  .article__lead {
    font-size: 1.2rem;
    line-height: 1.7;
    opacity: 0.8;
  }

  .article__body {
    max-width: 720px;
  }

  .article__body h2 {
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
    font-size: 1.6rem;
  }

  .article__body h2:first-child {
    margin-top: 0;
  }

  .article__body p {
    margin-bottom: var(--space-md);
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .components-section {
    padding-top: 0;
  }

  .components-grid {
    margin-top: var(--space-lg);
  }

  .component-card h4 {
    margin-bottom: var(--space-xs);
    font-size: 1.1rem;
  }

  .component-card p {
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .mavek-section .article__body h2 {
    margin-top: var(--space-sm);
  }

  .related-section {
    padding-bottom: 0;
  }

  .related-section .article__body h2 {
    margin-top: 0;
    margin-bottom: var(--space-md);
  }

  .related-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .related-link {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1rem;
    color: var(--gold-dark);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: var(--space-sm) 0;
    border-bottom: 1px solid rgba(26, 26, 24, 0.08);
    transition: all 0.2s ease;
  }

  .related-link:hover {
    gap: 0.9rem;
    border-bottom-color: var(--gold-mid);
  }

  .related-link:last-child {
    border-bottom: none;
  }

  @media (max-width: 900px) {
    .components-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .components-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
