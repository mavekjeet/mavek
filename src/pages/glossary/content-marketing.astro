---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import CTASection from '../../components/CTASection.astro';
import Footer from '../../components/Footer.astro';

const components = [
  {
    title: "Content Strategy",
    description: "The plan that defines what content to create, who it is for, which channels to distribute it on, and how it ties back to business goals.",
  },
  {
    title: "Content Creation",
    description: "Writing blog posts, producing videos, designing infographics, and building resources that educate, entertain, or solve problems for your target audience.",
  },
  {
    title: "Content Distribution",
    description: "Publishing and promoting content across owned channels like your blog and email list, and earned channels like social media and guest publications.",
  },
  {
    title: "SEO Integration",
    description: "Optimizing content for search engines through keyword research, on-page optimization, internal linking, and technical best practices to drive organic traffic.",
  },
  {
    title: "Performance Measurement",
    description: "Tracking traffic, engagement, conversions, and revenue attribution to understand which content drives results and which falls flat.",
  },
];

const relatedTerms = [
  { term: "Search Engine Optimization (SEO)", slug: "search-engine-optimization" },
  { term: "Lead Generation", slug: "lead-generation" },
  { term: "Brand Voice", slug: "brand-voice" },
  { term: "Marketing Funnel", slug: "marketing-funnel" },
];
---

<Layout title="What Is Content Marketing? Definition & Guide" description="Content marketing is a strategy focused on creating valuable content to attract and retain an audience. Learn what it is, its key components, and how Mavek automates content at scale.">
  <Nav />

  <article class="section light glossary-article" style="padding-top: calc(var(--nav-height) + var(--space-3xl));">
    <div class="container">
      <div class="article__header reveal">
        <a href="/glossary" class="article__back">&larr; Back to Glossary</a>
        <span class="sec-label">Glossary</span>
        <h1>Content Marketing</h1>
        <p class="article__lead">A strategic approach to creating and distributing valuable, relevant content to attract, engage, and convert a clearly defined audience -- without resorting to interruptive advertising.</p>
      </div>

      <div class="article__body reveal">
        <h2>What is <em>content marketing</em>?</h2>
        <p>Content marketing is the practice of creating and sharing useful, relevant content -- blog posts, videos, guides, podcasts, newsletters -- to attract a target audience and drive profitable customer action. Instead of pitching your product directly, you provide genuinely helpful information that builds trust and positions your brand as an authority.</p>
        <p>The approach works because modern buyers do their own research before talking to sales. By the time a prospect reaches out, they have already consumed multiple pieces of content and formed an opinion about your brand. Content marketing lets you shape that opinion from the first touchpoint.</p>
        <p>Done well, content marketing compounds over time. A blog post published today can generate traffic, leads, and revenue for years. Unlike paid ads that stop working the moment you stop paying, content builds a moat of organic visibility that grows with every piece you publish.</p>
      </div>
    </div>
  </article>

  <section class="section light components-section">
    <div class="container">
      <div class="article__body reveal">
        <h2>Key components of <em>content marketing</em></h2>
        <p>Content marketing is more than writing blog posts. It is a system of interconnected disciplines.</p>
      </div>
      <div class="grid-3 components-grid">
        {components.map((item, i) => (
          <div class="card component-card reveal" style={`transition-delay: ${i * 0.06}s`}>
            <h4>{item.title}</h4>
            <p>{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section dark mavek-section">
    <div class="container">
      <div class="article__body reveal">
        <span class="sec-label">How Mavek Approaches It</span>
        <h2>Content that writes, publishes, and <em>optimizes itself</em></h2>
        <p>Traditional content marketing requires a strategist, a writer, an SEO specialist, and an analyst. Each person handles one piece of the puzzle, and coordination between them is where most content programs stall.</p>
        <p>Mavek collapses the entire content workflow into a single autonomous system. It researches keywords, identifies content gaps, writes original long-form posts in your brand voice, optimizes for search, publishes on schedule, and tracks performance -- all without waiting for a human to move the baton between stages.</p>
        <p>The key difference is that Mavek does not produce generic AI content. Its memory layer stores your brand guidelines, tone of voice, past performance data, and audience insights. Every piece it creates is informed by what has worked before and tailored to your specific market -- then reviewed through built-in approval gates before publication.</p>
      </div>
    </div>
  </section>

  <section class="section light related-section">
    <div class="container">
      <div class="article__body reveal">
        <h2>Related terms</h2>
        <div class="related-grid">
          {relatedTerms.map(item => (
            <a href={`/glossary/${item.slug}`} class="related-link">
              {item.term} <span>&rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="Scale your content without scaling your team"
    subtitle="Mavek creates, optimizes, and publishes content autonomously -- in your brand voice."
    primaryCta="Get Started"
    primaryHref="/contact"
    secondaryCta="How It Works"
    secondaryHref="/how-it-works"
  />

  <Footer />
</Layout>

<style>
  .article__header {
    max-width: 720px;
    margin-bottom: var(--space-xl);
  }

  .article__back {
    font-family: var(--font-body);
    font-size: 0.75rem;
    opacity: 0.5;
    margin-bottom: var(--space-md);
    display: inline-block;
    transition: opacity 0.2s ease;
  }

  .article__back:hover {
    opacity: 1;
    color: var(--gold-dark);
  }

  .article__header .sec-label {
    display: block;
    margin-bottom: var(--space-xs);
  }

  .article__header h1 {
    margin-bottom: var(--space-md);
    font-size: clamp(2rem, 4.5vw, 3.2rem);
  }

  .article__lead {
    font-size: 1.2rem;
    line-height: 1.7;
    opacity: 0.8;
  }

  .article__body {
    max-width: 720px;
  }

  .article__body h2 {
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
    font-size: 1.6rem;
  }

  .article__body h2:first-child {
    margin-top: 0;
  }

  .article__body p {
    margin-bottom: var(--space-md);
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .components-section {
    padding-top: 0;
  }

  .components-grid {
    margin-top: var(--space-lg);
  }

  .component-card h4 {
    margin-bottom: var(--space-xs);
    font-size: 1.1rem;
  }

  .component-card p {
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .mavek-section .article__body h2 {
    margin-top: var(--space-sm);
  }

  .related-section {
    padding-bottom: 0;
  }

  .related-section .article__body h2 {
    margin-top: 0;
    margin-bottom: var(--space-md);
  }

  .related-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .related-link {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1rem;
    color: var(--gold-dark);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: var(--space-sm) 0;
    border-bottom: 1px solid rgba(26, 26, 24, 0.08);
    transition: all 0.2s ease;
  }

  .related-link:hover {
    gap: 0.9rem;
    border-bottom-color: var(--gold-mid);
  }

  .related-link:last-child {
    border-bottom: none;
  }

  @media (max-width: 900px) {
    .components-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .components-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
