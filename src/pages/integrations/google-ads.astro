---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import CTASection from '../../components/CTASection.astro';
import Footer from '../../components/Footer.astro';

const connected = [
  { item: "Campaigns & ad groups", desc: "Full structure including settings, statuses, and targeting configurations." },
  { item: "Keywords & bids", desc: "Every keyword, match type, and bid amount across all campaigns." },
  { item: "Budgets", desc: "Daily and shared budgets with spend pacing data." },
  { item: "Conversion data", desc: "All conversion actions, values, and attribution windows." },
  { item: "Quality Scores", desc: "Keyword-level quality scores, expected CTR, ad relevance, and landing page experience." },
  { item: "Search terms", desc: "Actual queries triggering your ads, with performance metrics." },
];

const actions = [
  { title: "Autonomous bid optimization", desc: "Mavek adjusts bids in real time based on conversion probability, day-parting patterns, and competitive pressure. No rules to configure." },
  { title: "Ad copy testing", desc: "Generates and rotates responsive search ad variants, measures statistical significance, and promotes winners automatically." },
  { title: "Negative keyword management", desc: "Continuously mines search terms for wasted spend, adds negatives, and maintains conflict-free keyword lists." },
  { title: "Budget reallocation", desc: "Shifts budget from underperforming campaigns to high-ROI opportunities daily, keeping total spend on target." },
  { title: "Performance reporting", desc: "Weekly and monthly reports with actionable insights, trend analysis, and plain-English recommendations delivered to your inbox." },
];

const steps = [
  { step: "01", title: "Connect via OAuth", desc: "Click connect, authorize Mavek in your Google account. Read/write access to Ads only. Takes 30 seconds." },
  { step: "02", title: "Set your goals", desc: "Tell Mavek your target CPA, ROAS, or budget constraints. It calibrates its strategy around your numbers." },
  { step: "03", title: "Mavek takes over", desc: "Within 24 hours, Mavek begins optimizing. You approve major changes. Everything else runs autonomously." },
];
---

<Layout title="Google Ads Integration" description="Mavek connects to Google Ads for autonomous bid optimization, ad copy testing, negative keyword management, and budget reallocation.">
  <Nav />

  <section class="section light detail-hero" style="padding-top: calc(var(--nav-height) + var(--space-3xl));">
    <div class="container">
      <a href="/integrations" class="back-link reveal">&larr; All Integrations</a>
      <div class="detail__header reveal">
        <span class="sec-label">Integration</span>
        <h1>Google Ads</h1>
        <p class="detail__lead">Mavek connects directly to your Google Ads account via OAuth, reads your entire campaign structure, and starts optimizing autonomously. No scripts. No manual rules. No spreadsheet exports.</p>
      </div>
    </div>
  </section>

  <section class="section dark">
    <div class="container">
      <div class="section__header reveal">
        <span class="sec-label">Data Access</span>
        <h2>What gets <em>connected</em></h2>
        <p>Mavek pulls these data points in real time to build a complete picture of your account.</p>
      </div>
      <div class="grid-3">
        {connected.map((c, i) => (
          <div class="card card--dark reveal" style={`transition-delay: ${i * 0.06}s; padding: var(--space-md);`}>
            <h4 class="card__title">{c.item}</h4>
            <p class="card__desc">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section light">
    <div class="container">
      <div class="section__header reveal">
        <span class="sec-label">Capabilities</span>
        <h2>What Mavek <em>does with it</em></h2>
        <p>Not just dashboards. Mavek takes action on your behalf, within guardrails you set.</p>
      </div>
      <div class="actions-list">
        {actions.map((a, i) => (
          <div class="action-item reveal" style={`transition-delay: ${i * 0.08}s`}>
            <div class="action-item__marker"></div>
            <div class="action-item__content">
              <h3>{a.title}</h3>
              <p>{a.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section dark">
    <div class="container">
      <div class="section__header reveal">
        <span class="sec-label">Setup</span>
        <h2>Live in <em>three steps</em></h2>
      </div>
      <div class="grid-3">
        {steps.map((s, i) => (
          <div class="step-card reveal" style={`transition-delay: ${i * 0.1}s`}>
            <span class="step-card__number">{s.step}</span>
            <h4>{s.title}</h4>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section light">
    <div class="container">
      <div class="security-note reveal" style="max-width: 640px;">
        <span class="sec-label">Data Security</span>
        <h2>Built on <em>trust</em></h2>
        <p>Mavek uses Google's OAuth 2.0 protocol. Your credentials are never stored on our servers. All data is encrypted in transit (TLS 1.3) and at rest (AES-256). You control exactly which accounts Mavek can access, and you can revoke permissions instantly from your Google account settings.</p>
        <p>We request only the scopes necessary for campaign management. Mavek cannot access your Gmail, Drive, or any other Google service.</p>
      </div>
    </div>
  </section>

  <CTASection
    title="Connect Google Ads in 30 seconds."
    subtitle="Start optimizing your campaigns today with autonomous bid management and ad copy testing."
    primaryCta="Get Started"
    primaryHref="/contact"
    secondaryCta="View All Integrations"
    secondaryHref="/integrations"
  />

  <Footer />
</Layout>

<style>
  .back-link {
    font-family: var(--font-body);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gold-dark);
    display: inline-block;
    margin-bottom: var(--space-md);
    transition: opacity var(--duration) var(--ease);
  }
  .back-link:hover { opacity: 0.6; }

  .detail__header {
    max-width: 680px;
  }
  .detail__header h1 {
    margin-top: var(--space-xs);
    margin-bottom: var(--space-md);
  }
  .detail__lead {
    font-size: 1.15rem;
    line-height: 1.7;
    opacity: 0.8;
    max-width: 560px;
  }

  .section__header {
    text-align: center;
    max-width: 540px;
    margin: 0 auto var(--space-xl);
  }
  .section__header h2 { margin-top: var(--space-xs); margin-bottom: var(--space-xs); }

  .card__title {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.95rem;
    color: #F5F5F7;
    margin-bottom: 0.25rem;
  }
  .card__desc { font-size: 0.85rem; }

  .actions-list {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    padding-left: 2rem;
  }
  .actions-list::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: rgba(26,26,24,0.08);
  }
  .action-item {
    position: relative;
    margin-bottom: var(--space-xl);
  }
  .action-item:last-child { margin-bottom: 0; }
  .action-item__marker {
    position: absolute;
    left: -2rem;
    top: 0.4rem;
    width: 12px;
    height: 12px;
    background: var(--gold-mid);
    margin-left: -5px;
  }
  .action-item__content h3 {
    font-size: 1.25rem;
    margin-bottom: var(--space-xs);
  }
  .action-item__content p { font-size: 0.95rem; }

  .step-card {
    padding: var(--space-lg);
    background: var(--dark-card);
    border: 1px solid var(--dark-border);
    border-radius: 10px;
  }
  .step-card__number {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--gold-mid);
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: var(--space-xs);
  }
  .step-card h4 {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1.05rem;
    margin-bottom: var(--space-xs);
    color: #F5F5F7;
  }
  .step-card p { font-size: 0.9rem; }

  .security-note h2 { margin-top: var(--space-xs); margin-bottom: var(--space-sm); }
  .security-note p { margin-bottom: var(--space-sm); }
  .security-note p:last-child { margin-bottom: 0; }
</style>
