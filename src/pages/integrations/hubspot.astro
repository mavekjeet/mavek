---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import CTASection from '../../components/CTASection.astro';
import Footer from '../../components/Footer.astro';

const connected = [
  { item: "Contacts & companies", desc: "Full contact database including properties, lifecycle stages, and company associations." },
  { item: "Deals & pipelines", desc: "Every deal, deal stage, amount, close date, and custom pipeline configuration." },
  { item: "Email templates", desc: "Sales email templates, sequences, and historical send/open/reply performance data." },
  { item: "Workflows", desc: "Existing automation workflows, enrollment criteria, and action configurations." },
  { item: "Lists & segments", desc: "Static and active lists, segmentation criteria, and membership data." },
  { item: "Activity timeline", desc: "Emails, calls, meetings, notes, and task history across all contacts and deals." },
];

const actions = [
  { title: "Intelligent lead scoring", desc: "Mavek analyzes engagement signals, firmographic data, and behavioral patterns to score leads with far more nuance than rule-based scoring. Scores update continuously as new data comes in." },
  { title: "Pipeline management", desc: "Automatically updates deal stages based on activity signals, flags stalled deals, and surfaces at-risk opportunities before they slip. Keeps your pipeline accurate without manual data entry." },
  { title: "Automated outreach sequences", desc: "Builds and sends personalized email sequences using your templates and brand voice. Adjusts send timing, follow-up cadence, and messaging based on recipient behavior." },
  { title: "Deal stage tracking", desc: "Monitors every deal's progression against historical benchmarks. Alerts you when deals deviate from expected timelines and recommends next actions to move them forward." },
  { title: "CRM-informed content", desc: "Uses your CRM data to generate content that speaks directly to your audience segments. Blog posts, landing pages, and email copy grounded in what your actual customers care about." },
];

const steps = [
  { step: "01", title: "Connect via OAuth", desc: "Authorize Mavek in your HubSpot portal. Select which hubs and objects Mavek can access. Takes 30 seconds." },
  { step: "02", title: "Map your goals", desc: "Define your pipeline stages, scoring criteria, and outreach preferences. Mavek adapts to your sales process." },
  { step: "03", title: "Mavek takes over", desc: "Mavek syncs your CRM data immediately and begins scoring, tracking, and automating. First actions within 24 hours." },
];
---

<Layout title="HubSpot Integration" description="Mavek connects to HubSpot for lead scoring, pipeline management, automated outreach sequences, and CRM-informed content creation.">
  <Nav />

  <section class="section light detail-hero" style="padding-top: calc(var(--nav-height) + var(--space-3xl));">
    <div class="container">
      <a href="/integrations" class="back-link reveal">&larr; All Integrations</a>
      <div class="detail__header reveal">
        <span class="sec-label">Integration</span>
        <h1>HubSpot</h1>
        <p class="detail__lead">Mavek connects to your HubSpot CRM via OAuth and turns your contact data, deals, and pipelines into an autonomous sales and marketing engine. No more manual data entry. No more stale pipelines.</p>
      </div>
    </div>
  </section>

  <section class="section dark">
    <div class="container">
      <div class="section__header reveal">
        <span class="sec-label">Data Access</span>
        <h2>What gets <em>connected</em></h2>
        <p>Mavek syncs these objects from your HubSpot portal to power intelligent automation.</p>
      </div>
      <div class="grid-3">
        {connected.map((c, i) => (
          <div class="card card--dark reveal" style={`transition-delay: ${i * 0.06}s; padding: var(--space-md);`}>
            <h4 class="card__title">{c.item}</h4>
            <p class="card__desc">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section light">
    <div class="container">
      <div class="section__header reveal">
        <span class="sec-label">Capabilities</span>
        <h2>What Mavek <em>does with it</em></h2>
        <p>Autonomous CRM management that keeps your pipeline clean and your outreach sharp.</p>
      </div>
      <div class="actions-list">
        {actions.map((a, i) => (
          <div class="action-item reveal" style={`transition-delay: ${i * 0.08}s`}>
            <div class="action-item__marker"></div>
            <div class="action-item__content">
              <h3>{a.title}</h3>
              <p>{a.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section dark">
    <div class="container">
      <div class="section__header reveal">
        <span class="sec-label">Setup</span>
        <h2>Live in <em>three steps</em></h2>
      </div>
      <div class="grid-3">
        {steps.map((s, i) => (
          <div class="step-card reveal" style={`transition-delay: ${i * 0.1}s`}>
            <span class="step-card__number">{s.step}</span>
            <h4>{s.title}</h4>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section light">
    <div class="container">
      <div class="security-note reveal" style="max-width: 640px;">
        <span class="sec-label">Data Security</span>
        <h2>Built on <em>trust</em></h2>
        <p>Mavek uses HubSpot's official OAuth 2.0 integration protocol. Your credentials are never stored on our servers. All CRM data is encrypted in transit (TLS 1.3) and at rest (AES-256). You control which hubs and objects Mavek can access.</p>
        <p>Permissions can be revoked at any time from your HubSpot portal settings. Mavek only requests the API scopes necessary for CRM management, email, and reporting.</p>
      </div>
    </div>
  </section>

  <CTASection
    title="Connect HubSpot in 30 seconds."
    subtitle="Start automating your pipeline, lead scoring, and outreach with CRM-powered intelligence."
    primaryCta="Get Started"
    primaryHref="/contact"
    secondaryCta="View All Integrations"
    secondaryHref="/integrations"
  />

  <Footer />
</Layout>

<style>
  .back-link {
    font-family: var(--font-body);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gold-dark);
    display: inline-block;
    margin-bottom: var(--space-md);
    transition: opacity var(--duration) var(--ease);
  }
  .back-link:hover { opacity: 0.6; }

  .detail__header {
    max-width: 680px;
  }
  .detail__header h1 {
    margin-top: var(--space-xs);
    margin-bottom: var(--space-md);
  }
  .detail__lead {
    font-size: 1.15rem;
    line-height: 1.7;
    opacity: 0.8;
    max-width: 560px;
  }

  .section__header {
    text-align: center;
    max-width: 540px;
    margin: 0 auto var(--space-xl);
  }
  .section__header h2 { margin-top: var(--space-xs); margin-bottom: var(--space-xs); }

  .card__title {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.95rem;
    color: #F5F5F7;
    margin-bottom: 0.25rem;
  }
  .card__desc { font-size: 0.85rem; }

  .actions-list {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    padding-left: 2rem;
  }
  .actions-list::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: rgba(26,26,24,0.08);
  }
  .action-item {
    position: relative;
    margin-bottom: var(--space-xl);
  }
  .action-item:last-child { margin-bottom: 0; }
  .action-item__marker {
    position: absolute;
    left: -2rem;
    top: 0.4rem;
    width: 12px;
    height: 12px;
    background: var(--gold-mid);
    margin-left: -5px;
  }
  .action-item__content h3 {
    font-size: 1.25rem;
    margin-bottom: var(--space-xs);
  }
  .action-item__content p { font-size: 0.95rem; }

  .step-card {
    padding: var(--space-lg);
    background: var(--dark-card);
    border: 1px solid var(--dark-border);
    border-radius: 10px;
  }
  .step-card__number {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--gold-mid);
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: var(--space-xs);
  }
  .step-card h4 {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1.05rem;
    margin-bottom: var(--space-xs);
    color: #F5F5F7;
  }
  .step-card p { font-size: 0.9rem; }

  .security-note h2 { margin-top: var(--space-xs); margin-bottom: var(--space-sm); }
  .security-note p { margin-bottom: var(--space-sm); }
  .security-note p:last-child { margin-bottom: 0; }
</style>
