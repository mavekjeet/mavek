---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Testimonials from '../components/Testimonials.astro';
import CTASection from '../components/CTASection.astro';
import Footer from '../components/Footer.astro';

const painPoints = [
  {
    problem: "Can't afford a full marketing team",
    solution: "Mavek gives you enterprise-grade marketing execution for under $500/month. One platform instead of five hires.",
  },
  {
    problem: "Agency costs are crushing margins",
    solution: "Stop paying agency retainers for work that could be automated. Get transparent execution at a fraction of the cost.",
  },
  {
    problem: "Marketing feels like guesswork",
    solution: "Mavek uses your data, not generic templates. Every campaign, content piece, and outreach is grounded in what works for you.",
  },
];

const brandFeatures = [
  { title: "Full-Funnel Marketing", desc: "Paid ads, SEO, content, outreach, and analytics, all running simultaneously under one roof." },
  { title: "Brand Voice Learning", desc: "Mavek absorbs your tone, style, and messaging. Content feels like your team wrote it." },
  { title: "Always-On Execution", desc: "Marketing runs 24/7. Campaigns optimize while you sleep. Growth compounds overnight." },
  { title: "Human Approval Gates", desc: "Nothing goes live without your sign-off. Full control, zero bottleneck." },
  { title: "Real-Time Analytics", desc: "See exactly what's working across every channel. Attribution that actually makes sense." },
  { title: "Zero Onboarding Friction", desc: "Connect your accounts, share your brand context, and Mavek starts executing in days, not months." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is Mavek and how does it work for brands?", "acceptedAnswer": { "@type": "Answer", "text": "Mavek is an AI-powered marketing execution platform that gives brands enterprise-grade marketing capabilities for under $500/month. It handles paid ads, SEO, content creation, email outreach, and analytics autonomously, learning your brand voice, audience, and data to deliver personalized campaigns without requiring a full marketing team." }},
    { "@type": "Question", "name": "How much does Mavek cost compared to hiring a marketing team?", "acceptedAnswer": { "@type": "Answer", "text": "A full in-house marketing team (ads manager, SEO specialist, content writer, outreach manager, analyst) costs $3,600+ per month minimum. Mavek delivers comparable execution across all these functions starting at $299/month, roughly 1/10th the cost of a traditional team, with no hiring, onboarding, or management overhead." }},
    { "@type": "Question", "name": "Will AI-generated content sound like my brand?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Mavek's Memory Layer absorbs your brand's tone, style, messaging, and audience data. Over time, content becomes increasingly aligned with your voice. Brands report that Mavek-generated content is indistinguishable from what their best in-house writers produce." }},
    { "@type": "Question", "name": "Do I lose control over what gets published?", "acceptedAnswer": { "@type": "Answer", "text": "No. Mavek includes human approval gates on every workflow. Nothing is published, sent, or launched without your explicit sign-off. You maintain full editorial and strategic control. For workflows you trust, you can optionally enable auto-approve to accelerate execution." }},
    { "@type": "Question", "name": "How long does it take to set up Mavek?", "acceptedAnswer": { "@type": "Answer", "text": "Most brands are fully operational within 48 hours. Setup involves connecting your marketing accounts via one-click OAuth (Google Ads, Meta Ads, Google Analytics, etc.), sharing your brand context, and defining your goals. No engineering or technical skills required." }},
    { "@type": "Question", "name": "Does Mavek make my marketing agency obsolete?", "acceptedAnswer": { "@type": "Answer", "text": "For many brands, yes. Mavek handles the execution work that agencies typically charge premium retainers for, including ad management, content production, SEO optimization, and reporting. You keep strategic decision-making in-house while Mavek handles the daily execution, often at a fraction of agency costs." }},
  ]
};
---

<Layout title="For Brands" description="Your entire marketing department for under $500/month. Enterprise execution without the enterprise team." schema={faqSchema}>
  <Nav />

  <Hero
    eyebrow="FOR BRANDS"
    title="Your marketing, handled."
    highlight="handled"
    subtitle="Enterprise-grade marketing execution under $500/month. No hiring, no managing, no guessing. Just results."
    primaryCta="Book a Demo"
    primaryHref="/contact"
    secondaryCta="See Pricing"
    secondaryHref="/pricing"
  >
    <div class="hero__dashboard">
      <div class="dash__header">
        <div class="dash__dots"><span></span><span></span><span></span></div>
        <span class="dash__title">Your Marketing Dashboard</span>
      </div>
      <div class="dash__body">
        <div class="dash__sidebar">
          <div class="dash__nav-item active">Overview</div>
          <div class="dash__nav-item">SEO</div>
          <div class="dash__nav-item">Ads</div>
          <div class="dash__nav-item">Email</div>
        </div>
        <div class="dash__main">
          <div class="dash__stats">
            <div class="dash__stat">
              <span class="dash__stat-label">Campaigns</span>
              <span class="dash__stat-value">6</span>
            </div>
            <div class="dash__stat">
              <span class="dash__stat-label">Leads</span>
              <span class="dash__stat-value">312</span>
            </div>
            <div class="dash__stat">
              <span class="dash__stat-label">ROI</span>
              <span class="dash__stat-value">4.2x</span>
            </div>
          </div>
          <div class="dash__chart">
            <div class="dash__chart-bars">
              <div class="dash__bar" data-height="35%"></div>
              <div class="dash__bar" data-height="50%"></div>
              <div class="dash__bar" data-height="45%"></div>
              <div class="dash__bar" data-height="60%"></div>
              <div class="dash__bar" data-height="75%"></div>
              <div class="dash__bar" data-height="70%"></div>
              <div class="dash__bar gold" data-height="85%"></div>
              <div class="dash__bar gold" data-height="92%"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Hero>

  <section class="dark">
    <div class="container">
      <div class="pain__header reveal">
        <span class="sec-label">The Brand Challenge</span>
        <h2>Great marketing shouldn't require <em>a huge team</em></h2>
      </div>
      <div class="pain__grid grid-3">
        {painPoints.map((p, i) => (
          <div class="card card--dark reveal" style={`transition-delay: ${i * 0.1}s`}>
            <h4 class="pain__problem">{p.problem}</h4>
            <p>{p.solution}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="light">
    <div class="container">
      <div class="brand-features__header reveal">
        <span class="sec-label">Built for Growing Brands</span>
        <h2>Everything you need. <em>Nothing you don't.</em></h2>
      </div>
      <div class="grid-3">
        {brandFeatures.map((f, i) => (
          <div class="card reveal" style={`transition-delay: ${i * 0.08}s`}>
            <h4>{f.title}</h4>
            <p style="font-size: 0.9rem; margin-top: 0.5rem;">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <HowItWorks />

  <Testimonials />

  <section class="light faq-aeo">
    <div class="container">
      <div class="faq-aeo__header reveal">
        <span class="sec-label">Frequently Asked Questions</span>
        <h2>AI Marketing for Brands: <em>Common Questions</em></h2>
      </div>
      <div class="faq-aeo__list">
        <details class="faq-aeo__item reveal">
          <summary>What is Mavek and how does it work for brands?</summary>
          <p>Mavek is an AI-powered marketing execution platform that gives brands enterprise-grade marketing capabilities for under $500/month. It handles paid ads, SEO, content creation, email outreach, and analytics autonomously, learning your brand voice, audience, and data to deliver personalized campaigns without requiring a full marketing team.</p>
        </details>
        <details class="faq-aeo__item reveal">
          <summary>How much does Mavek cost compared to hiring a marketing team?</summary>
          <p>A full in-house marketing team (ads manager, SEO specialist, content writer, outreach manager, analyst) costs $3,600+ per month minimum. Mavek delivers comparable execution across all these functions starting at $299/month, roughly 1/10th the cost of a traditional team, with no hiring, onboarding, or management overhead.</p>
        </details>
        <details class="faq-aeo__item reveal">
          <summary>Will AI-generated content sound like my brand?</summary>
          <p>Yes. Mavek's Memory Layer absorbs your brand's tone, style, messaging, and audience data. Over time, content becomes increasingly aligned with your voice. Brands report that Mavek-generated content is indistinguishable from what their best in-house writers produce.</p>
        </details>
        <details class="faq-aeo__item reveal">
          <summary>Do I lose control over what gets published?</summary>
          <p>No. Mavek includes human approval gates on every workflow. Nothing is published, sent, or launched without your explicit sign-off. You maintain full editorial and strategic control. For workflows you trust, you can optionally enable auto-approve to accelerate execution.</p>
        </details>
        <details class="faq-aeo__item reveal">
          <summary>How long does it take to set up Mavek?</summary>
          <p>Most brands are fully operational within 48 hours. Setup involves connecting your marketing accounts via one-click OAuth (Google Ads, Meta Ads, Google Analytics, etc.), sharing your brand context, and defining your goals. No engineering or technical skills required.</p>
        </details>
        <details class="faq-aeo__item reveal">
          <summary>Does Mavek make my marketing agency obsolete?</summary>
          <p>For many brands, yes. Mavek handles the execution work that agencies typically charge premium retainers for, including ad management, content production, SEO optimization, and reporting. You keep strategic decision-making in-house while Mavek handles the daily execution, often at a fraction of agency costs.</p>
        </details>
      </div>
    </div>
  </section>

  <CTASection
    title="Stop paying for a team you don't need."
    subtitle="One platform. Enterprise execution. Under $500/month."
  />

  <Footer />
</Layout>

<style>
  .pain__header, .brand-features__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }
  .pain__header h2, .brand-features__header h2 { margin-top: var(--space-xs); }
  .pain__problem { color: #F5F5F7; margin-bottom: var(--space-xs); }

  .faq-aeo__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }
  .faq-aeo__header h2 { margin-top: var(--space-xs); }
  .faq-aeo__list {
    max-width: 720px;
    margin: 0 auto;
  }
  .faq-aeo__item {
    border-bottom: 1px solid rgba(26,26,24,0.08);
    padding: var(--space-md) 0;
  }
  .faq-aeo__item summary {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1.05rem;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .faq-aeo__item summary::-webkit-details-marker { display: none; }
  .faq-aeo__item summary::after {
    content: '+';
    font-size: 1.5rem;
    color: var(--gold-mid);
    font-weight: 300;
    transition: transform 0.2s ease;
  }
  .faq-aeo__item[open] summary::after { content: '-'; }
  .faq-aeo__item p {
    margin-top: var(--space-sm);
    font-size: 0.95rem;
    line-height: 1.7;
    opacity: 0.7;
    max-width: 640px;
  }
</style>
