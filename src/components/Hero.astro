---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  primaryCta?: string;
  primaryHref?: string;
  secondaryCta?: string;
  secondaryHref?: string;
  dark?: boolean;
  showStone?: boolean;
}

const {
  eyebrow,
  title,
  subtitle,
  primaryCta = "Get Started",
  primaryHref = "/contact",
  secondaryCta,
  secondaryHref,
  dark = false,
  showStone = false,
} = Astro.props;
---

<section class:list={["hero", dark ? "dark" : "light"]}>
  <div class="container hero__inner">
    <div class="hero__content">
      {eyebrow && <div class="sec-label reveal">{eyebrow}</div>}
      <h1 class="reveal reveal-d1" set:html={title} />
      {subtitle && <p class="sub reveal reveal-d2">{subtitle}</p>}
      <div class="hero__actions reveal reveal-d3">
        <a href={primaryHref} class:list={["btn", dark ? "btn-gold" : "btn--primary"]}>{primaryCta} <span>&rarr;</span></a>
        {secondaryCta && secondaryHref && (
          <a href={secondaryHref} class:list={["btn", dark ? "btn-outline-gold" : "btn--secondary"]}>{secondaryCta}</a>
        )}
      </div>
    </div>
    <div class="hero__visual reveal reveal-d2">
      <slot>
        {showStone ? (
          <div class="hero__stone-wrap">
            <svg width="200" height="260" viewBox="0 0 200 280" id="heroStone">
              <ellipse id="stoneShadow" cx="100" cy="226.52" rx="58" ry="8" fill={dark ? "#D4B65A" : "#1A1A18"} opacity={dark ? "0.12" : "0.07"} data-op-min={dark ? "0.08" : "0.05"} data-op-max={dark ? "0.15" : "0.08"}/>
              <g id="stoneGroup" transform="translate(100, 115)">
                <path d="M-68 0 L-30.6 -54.4 L0 -54.4 L0 0 Z" fill="#E8C95A"/>
                <path d="M0 -54.4 L30.6 -54.4 L68 0 L0 0 Z" fill="#8A7028"/>
                <path d="M-68 0 L0 0 L0 81.6 Z" fill="#33302A"/>
                <path d="M0 0 L68 0 L0 81.6 Z" fill="#0A0A08"/>
              </g>
            </svg>
          </div>
        ) : (
          <div class="hero__dashboard">
            <div class="dash__header">
              <div class="dash__dots"><span></span><span></span><span></span></div>
              <span class="dash__title">Mavek Dashboard</span>
            </div>
            <div class="dash__body">
              <div class="dash__sidebar">
                <div class="dash__nav-item active">Overview</div>
                <div class="dash__nav-item">Campaigns</div>
                <div class="dash__nav-item">Content</div>
                <div class="dash__nav-item">Insights</div>
              </div>
              <div class="dash__main">
                <div class="dash__stats">
                  <div class="dash__stat">
                    <span class="dash__stat-label">Leads</span>
                    <span class="dash__stat-value">142</span>
                  </div>
                  <div class="dash__stat">
                    <span class="dash__stat-label">Campaigns</span>
                    <span class="dash__stat-value">18</span>
                  </div>
                  <div class="dash__stat">
                    <span class="dash__stat-label">Traffic</span>
                    <span class="dash__stat-value">24k</span>
                  </div>
                </div>
                <div class="dash__chart">
                  <div class="dash__chart-bars">
                    <div class="dash__bar" data-height="40%"></div>
                    <div class="dash__bar" data-height="55%"></div>
                    <div class="dash__bar" data-height="45%"></div>
                    <div class="dash__bar" data-height="70%"></div>
                    <div class="dash__bar" data-height="60%"></div>
                    <div class="dash__bar" data-height="85%"></div>
                    <div class="dash__bar" data-height="75%"></div>
                    <div class="dash__bar gold" data-height="95%"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        )}
      </slot>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: calc(var(--nav-height) + 40px);
    padding-bottom: 60px;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .hero__content { max-width: 520px; }

  .hero__actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* Stone animation */
  .hero__stone-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* Dashboard Mock — :global needed for slot content */
  .hero__visual :global(.hero__dashboard) {
    background: var(--night);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 25px 80px rgba(0,0,0,0.2);
    border: 1px solid var(--night-4);
  }

  .hero__visual :global(.dash__header) {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: var(--night-2);
    border-bottom: 1px solid var(--night-4);
  }

  .hero__visual :global(.dash__dots) { display: flex; gap: 6px; }
  .hero__visual :global(.dash__dots span) { width: 10px; height: 10px; border-radius: 50%; }
  .hero__visual :global(.dash__dots span:first-child) { background: #C44B3F; }
  .hero__visual :global(.dash__dots span:nth-child(2)) { background: #D4A537; }
  .hero__visual :global(.dash__dots span:nth-child(3)) { background: #5A9E3E; }

  .hero__visual :global(.dash__title) {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    color: var(--cream-40);
    letter-spacing: 1px;
  }

  .hero__visual :global(.dash__body) { display: grid; grid-template-columns: 120px 1fr; min-height: 240px; }

  .hero__visual :global(.dash__sidebar) {
    padding: 14px;
    border-right: 1px solid var(--night-4);
  }

  .hero__visual :global(.dash__nav-item) {
    font-family: var(--font-body);
    font-size: 11px;
    color: var(--cream-40);
    padding: 6px 10px;
    border-radius: 4px;
    margin-bottom: 2px;
  }

  .hero__visual :global(.dash__nav-item.active) {
    background: rgba(201, 168, 76, 0.1);
    color: var(--gold-mid);
  }

  .hero__visual :global(.dash__main) { padding: 16px; }

  .hero__visual :global(.dash__stats) { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 16px; }

  .hero__visual :global(.dash__stat) {
    background: var(--night-2);
    padding: 10px;
    border-radius: 6px;
    border: 1px solid var(--night-4);
  }

  .hero__visual :global(.dash__stat-label) {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    color: var(--cream-40);
    letter-spacing: 1px;
    display: block;
    margin-bottom: 4px;
  }

  .hero__visual :global(.dash__stat-value) {
    font-family: var(--font-display);
    font-size: 22px;
    color: var(--cream);
  }

  .hero__visual :global(.dash__chart) {
    background: var(--night-2);
    padding: 14px;
    border-radius: 6px;
    border: 1px solid var(--night-4);
    height: 100px;
  }

  .hero__visual :global(.dash__chart-bars) { display: flex; align-items: flex-end; gap: 6px; height: 100%; }

  .hero__visual :global(.dash__bar) {
    flex: 1;
    background: var(--night-4);
    border-radius: 3px 3px 0 0;
    height: 0%;
    transition: height 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .hero__visual :global(.dash__bar.gold) { background: var(--gold-mid); }

  @media (max-width: 768px) {
    .hero__inner { grid-template-columns: 1fr; }
    .hero__content { max-width: 100%; }
    .hero__visual { margin-top: 32px; }
    .hero__visual :global(.dash__body) { grid-template-columns: 1fr; }
    .hero__visual :global(.dash__sidebar) { display: none; }
  }
</style>

<script is:inline>
  (function() {
    // Bar chart entrance animation
    var bars = document.querySelectorAll('.dash__bar[data-height]');
    if (bars.length) {
      setTimeout(function() {
        bars.forEach(function(bar, i) {
          setTimeout(function() {
            bar.style.height = bar.getAttribute('data-height');
          }, i * 100);
        });
      }, 400);
    }

    // Stone floating animation (hero only)
    // Per brand rules: shadow cy NEVER changes. Only rx, ry, and opacity animate.
    // Opacity range is read from data-attributes (bg-specific per brand spec).
    var stone = document.getElementById('stoneGroup');
    var shadow = document.getElementById('stoneShadow');
    if (stone && shadow) {
      var baseY = 115, amplitude = 14, duration = 4000;
      var rxMin = 50, rxMax = 62, ryMin = 6, ryMax = 10;
      var opMin = parseFloat(shadow.getAttribute('data-op-min')) || 0.05;
      var opMax = parseFloat(shadow.getAttribute('data-op-max')) || 0.08;

      function animateStone(time) {
        var t = (time % duration) / duration;
        var ease = (Math.sin(t * Math.PI * 2 - Math.PI / 2) + 1) / 2;
        stone.setAttribute('transform', 'translate(100, ' + (baseY - ease * amplitude) + ')');
        shadow.setAttribute('rx', (rxMin + ease * (rxMax - rxMin)).toFixed(1));
        shadow.setAttribute('ry', (ryMin + ease * (ryMax - ryMin)).toFixed(1));
        shadow.setAttribute('opacity', (opMax - ease * (opMax - opMin)).toFixed(3));
        requestAnimationFrame(animateStone);
      }
      requestAnimationFrame(animateStone);
    }
  })();
</script>
