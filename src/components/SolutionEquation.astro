---
/** Visual Equation — AI + Skills + Data + Humans = Mavek */
interface Props { dark?: boolean; }
const { dark = false } = Astro.props;

const ingredients = [
  {
    label: "AI Models",
    desc: "Foundation-level intelligence",
    svg: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="12" stroke="currentColor" stroke-width="1.5"/><circle cx="14" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M8 20c0-3.3 2.7-6 6-6s6 2.7 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M20 8l2-2M8 8L6 6M14 4V2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    label: "Expert Skills",
    desc: "Built by marketing specialists",
    svg: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="4" y="6" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M4 12h20" stroke="currentColor" stroke-width="1.5"/><path d="M10 6V4M18 6V4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M9 16.5l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    label: "Your Data",
    desc: "Real-time, cross-channel",
    svg: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M6 22V10l4 4 4-8 4 6 4-4v14H6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M6 22h16" stroke="currentColor" stroke-width="1.5"/></svg>`,
  },
  {
    label: "Human Team",
    desc: "Strategy & execution partners",
    svg: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/><circle cx="18" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M4 22c0-3.3 2.7-6 6-6M18 16c3.3 0 6 2.7 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M10 16c2.2 0 4 1.8 4 4v2M18 16c-2.2 0-4 1.8-4 4v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
];
---

<section class:list={["equation", dark ? "dark" : "light"]}>
  <div class="container">
    <div class="eq__header reveal">
      <span class="sec-label">Why Mavek</span>
      <h2>Four ingredients. <em>One team.</em></h2>
      <p class="sub eq__desc">Most AI tools give you a model and leave you to figure out the rest. Mavek gives you the full stack.</p>
    </div>

    <div class="eq__formula reveal">
      {ingredients.map((item, i) => (
        <>
          <div class="eq__ingredient">
            <div class="eq__icon" set:html={item.svg} />
            <div class="eq__label">{item.label}</div>
            <div class="eq__sub">{item.desc}</div>
          </div>
          {i < ingredients.length - 1 && <div class="eq__operator">+</div>}
        </>
      ))}
      <div class="eq__operator">=</div>
      <div class="eq__result">
        <div class="eq__stone-wrap">
          <svg width="60" height="80" viewBox="0 0 200 280" id="eqStone">
            <ellipse id="eqShadow" cx="100" cy="226.52" rx="58" ry="8" fill="#1A1A18" opacity="0.07" data-op-min="0.05" data-op-max="0.08"/>
            <g id="eqStoneGroup" transform="translate(100, 115)">
              <path d="M-68 0 L-30.6 -54.4 L0 -54.4 L0 0 Z" fill="#E8C95A"/>
              <path d="M0 -54.4 L30.6 -54.4 L68 0 L0 0 Z" fill="#8A7028"/>
              <path d="M-68 0 L0 0 L0 81.6 Z" fill="#33302A"/>
              <path d="M0 0 L68 0 L0 81.6 Z" fill="#0A0A08"/>
            </g>
          </svg>
        </div>
        <div class="eq__label">Mavek</div>
        <div class="eq__sub">Your full marketing team</div>
      </div>
    </div>

    <p class="eq__footnote reveal">AI and humans working together on your marketing. Not AI with humans as a fallback. A full partnership.</p>
  </div>
</section>

<style>
  .eq__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }
  .eq__header h2 {
    margin-top: var(--space-xs);
    font-family: var(--font-display);
    font-weight: 400;
  }
  .eq__header h2 em { font-style: italic; }
  .light .eq__header h2 em { color: var(--gold-dark); }
  .dark .eq__header h2 em { color: var(--gold-bright); }
  .sec-label {
    font-family: var(--font-body); font-size: 11px; font-weight: 500;
    letter-spacing: 4px; text-transform: uppercase;
  }
  .light .sec-label { color: var(--gold-dark); }
  .dark .sec-label { color: var(--gold-mid); }
  .eq__desc {
    max-width: 520px; margin: var(--space-md) auto 0;
  }
  .light .eq__desc { color: var(--ink-soft); }
  .dark .eq__desc { color: var(--cream-60); }

  .eq__formula {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
    padding: 48px 32px;
    border-radius: 12px;
    background: var(--surface);
    border: 1px solid rgba(26,26,24,0.06);
  }
  .dark .eq__formula {
    background: var(--night-3);
    border-color: rgba(201,168,76,0.1);
  }

  .eq__ingredient {
    text-align: center;
    min-width: 120px;
  }
  .eq__icon {
    margin-bottom: 8px;
    line-height: 1;
    display: flex;
    justify-content: center;
  }
  .light .eq__icon { color: var(--gold-dark); }
  .dark .eq__icon { color: var(--gold-mid); }

  .eq__label {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 2px;
  }
  .dark .eq__label { color: var(--cream); }
  .eq__sub {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.3px;
  }
  .light .eq__sub { color: var(--ink-muted); }
  .dark .eq__sub { color: var(--cream-40); }

  .eq__operator {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 300;
    line-height: 1;
    padding-bottom: 20px;
  }
  .light .eq__operator { color: var(--gold-dark); }
  .dark .eq__operator { color: var(--gold-mid); }

  .eq__result {
    text-align: center;
    min-width: 140px;
    padding: 16px 24px;
    border-radius: 10px;
    border: 2px solid var(--gold-mid);
    background: rgba(201,168,76,0.06);
  }
  .eq__stone-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 6px;
  }

  .eq__footnote {
    text-align: center;
    margin-top: var(--space-lg);
    font-size: 0.95rem;
    font-weight: 500;
  }
  .light .eq__footnote { color: var(--ink-soft); }
  .dark .eq__footnote { color: var(--cream-60); }

  @media (max-width: 768px) {
    .eq__formula { gap: 12px; padding: 32px 20px; }
    .eq__ingredient { min-width: 80px; }
    .eq__operator { font-size: 1.4rem; padding-bottom: 10px; }
  }
  @media (max-width: 520px) {
    .eq__formula { flex-direction: column; gap: 16px; }
    .eq__operator { padding-bottom: 0; transform: rotate(90deg); font-size: 1.2rem; }
  }
</style>

<script is:inline>
  (function() {
    var stone = document.getElementById('eqStoneGroup');
    var shadow = document.getElementById('eqShadow');
    if (!stone || !shadow) return;
    var baseY = 115, amplitude = 10, duration = 4000;
    var rxMin = 50, rxMax = 62, ryMin = 6, ryMax = 10;
    var opMin = 0.05, opMax = 0.08;
    function animate(time) {
      var t = (time % duration) / duration;
      var ease = (Math.sin(t * Math.PI * 2 - Math.PI / 2) + 1) / 2;
      stone.setAttribute('transform', 'translate(100, ' + (baseY - ease * amplitude) + ')');
      shadow.setAttribute('rx', (rxMin + ease * (rxMax - rxMin)).toFixed(1));
      shadow.setAttribute('ry', (ryMin + ease * (ryMax - ryMin)).toFixed(1));
      shadow.setAttribute('opacity', (opMax - ease * (opMax - opMin)).toFixed(3));
      requestAnimationFrame(animate);
    }
    requestAnimationFrame(animate);
  })();
</script>
