---
interface Props {
  dark?: boolean;
}
const { dark = false } = Astro.props;
---

<section class:list={[dark ? "dark" : "light", "dual"]}>
  <div class="container">
    <div class="dual__header reveal">
      <span class="sec-label">Built for two worlds</span>
      <h2>Whether you run an agency or a brand</h2>
    </div>
    <div class="dual__grid grid-2">
      <div class="dual__card reveal">
        <img src="/images/agency-team.jpg" alt="Agency team collaborating in a modern office" width="520" height="293" style="aspect-ratio: 16/9; object-fit: cover; width: 100%; height: auto; display: block;" loading="lazy" />
        <div class="dual__content">
          <span class="sec-label">For Agencies</span>
          <h3>Your team, <em>supercharged</em></h3>
          <p>10x campaign output without new hires. Mavek becomes your execution layer — you keep the strategy and client relationships.</p>
          <ul class="dual__list">
            <li>White-label execution at scale</li>
            <li>Multi-client campaign management</li>
            <li>Automated reporting and analytics</li>
            <li>Approval workflows your team controls</li>
          </ul>
          <a href="/for-agencies" class="btn btn--secondary">Learn more <span>&rarr;</span></a>
        </div>
      </div>
      <div class="dual__card reveal" style="transition-delay: 0.1s">
        <img src="/images/founder-metrics.jpg" alt="Founder reviewing marketing metrics on screen" width="520" height="293" style="aspect-ratio: 16/9; object-fit: cover; width: 100%; height: auto; display: block;" loading="lazy" />
        <div class="dual__content">
          <span class="sec-label">For Brands</span>
          <h3>Your marketing, <em>handled</em></h3>
          <p>Enterprise-grade marketing execution under $500/month. No hiring, no managing, no guessing — just results.</p>
          <ul class="dual__list">
            <li>Full-funnel marketing on autopilot</li>
            <li>Content, ads, SEO, and outreach</li>
            <li>Learns your brand voice and audience</li>
            <li>Human approval before anything goes live</li>
          </ul>
          <a href="/for-brands" class="btn btn--secondary">Learn more <span>&rarr;</span></a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .dual__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .dual__header h2 {
    margin-top: var(--space-xs);
    font-family: var(--font-display);
    font-weight: 400;
  }

  .sec-label {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--gold-dark);
  }

  .dual__card {
    background: var(--surface);
    border: 1.5px solid rgba(26,26,24,0.12);
    border-radius: 10px;
    overflow: hidden;
    transition: all var(--duration) var(--ease);
    box-shadow: 0 4px 20px rgba(26,26,24,0.06);
  }

  .dual__card:hover {
    border-color: var(--gold-dark);
    box-shadow: 0 12px 40px rgba(26,26,24,0.1);
  }

  .dual__content {
    padding: var(--space-lg);
  }

  .dual__content h3 {
    margin: var(--space-xs) 0 var(--space-sm);
    font-family: var(--font-display);
    font-weight: 400;
  }

  .dual__content h3 em {
    font-style: italic;
    color: var(--gold-dark);
  }

  .dual__content p {
    color: var(--ink-soft);
  }

  .dual__list {
    list-style: none;
    margin: var(--space-md) 0;
    padding: 0;
  }

  .dual__list li {
    position: relative;
    padding-left: 1.25rem;
    margin-bottom: 0.5rem;
    font-size: 14px;
    color: var(--ink-muted);
  }

  .dual__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5rem;
    width: 6px;
    height: 6px;
    background: var(--gold-dark);
    border-radius: 1px;
  }

  .dark .sec-label { color: var(--gold-mid); }

  .dark .dual__header h2 { color: var(--cream); }

  .dark .dual__card {
    background: var(--night-3);
    border-color: var(--night-4);
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
  }

  .dark .dual__card:hover {
    border-color: var(--gold-mid);
    box-shadow: 0 12px 40px rgba(0,0,0,0.3);
  }

  .dark .dual__content h3 { color: var(--cream); }
  .dark .dual__content h3 em { color: var(--gold-mid); }
  .dark .dual__content p { color: var(--cream-40); }
  .dark .dual__list li { color: var(--cream-40); }
  .dark .dual__list li::before { background: var(--gold-mid); }
  .dark .dual__content .btn { color: var(--cream); border-color: var(--cream-25); }
  .dark .dual__content .btn:hover { border-color: var(--gold-mid); color: var(--gold-mid); }
</style>
