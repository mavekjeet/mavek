---
const currentPath = Astro.url.pathname;
---

<a href="#main" class="skip-link">Skip to content</a>

<nav class="nav" id="mainNav">
  <div class="nav__inner">
    <a href="/" class="nav__logo">
      <!-- Stone logo -->
      <svg width="20" height="28" viewBox="0 0 20 28" class="nav__stone">
        <!-- S=8, stone-h=16, gap = 16×0.22 = 3.52, rx = 8×0.85 = 6.8. Girdle at y=8, tip at y=17.6, shadow at y=21.12. -->
        <ellipse cx="10" cy="21.12" rx="6.8" ry="1.5" fill="#1A1A18" opacity="0.07"/>
        <g transform="translate(10, 8)">
          <path d="M-8 0 L-3.6 -6.4 L0 -6.4 L0 0 Z" fill="#E8C95A"/>
          <path d="M0 -6.4 L3.6 -6.4 L8 0 L0 0 Z" fill="#8A7028"/>
          <path d="M-8 0 L0 0 L0 9.6 Z" fill="#33302A"/>
          <path d="M0 0 L8 0 L0 9.6 Z" fill="#0A0A08"/>
        </g>
      </svg>
      <span class="nav__wordmark">MA<span class="nav__v">V</span>EK</span>
    </a>

    <div class="nav__links" id="navLinks">
      <a href="/for-agencies" class:list={["nav__link", { active: currentPath === '/for-agencies' || currentPath === '/for-agencies/' }]} aria-current={currentPath === '/for-agencies' || currentPath === '/for-agencies/' ? 'page' : undefined}>For Agencies</a>
      <a href="/for-brands" class:list={["nav__link", { active: currentPath === '/for-brands' || currentPath === '/for-brands/' }]} aria-current={currentPath === '/for-brands' || currentPath === '/for-brands/' ? 'page' : undefined}>For Brands</a>
      <a href="/how-it-works" class:list={["nav__link", { active: currentPath === '/how-it-works' || currentPath === '/how-it-works/' }]} aria-current={currentPath === '/how-it-works' || currentPath === '/how-it-works/' ? 'page' : undefined}>How it works</a>
      <a href="/pricing" class:list={["nav__link", { active: currentPath === '/pricing' || currentPath === '/pricing/' }]} aria-current={currentPath === '/pricing' || currentPath === '/pricing/' ? 'page' : undefined}>Pricing</a>
      <a href="/tools" class:list={["nav__link", { active: currentPath.startsWith('/tools') }]} aria-current={currentPath.startsWith('/tools') ? 'page' : undefined}>Free Tools</a>
      <a href="/blog" class:list={["nav__link", { active: currentPath.startsWith('/blog') }]} aria-current={currentPath.startsWith('/blog') ? 'page' : undefined}>Blog</a>
    </div>

    <div class="nav__actions">
      <a href="/contact" class="btn btn--primary btn--sm">Talk to the Team</a>
    </div>

    <button class="nav__toggle" id="navToggle" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<style>
  .skip-link {
    position: fixed;
    top: -100%;
    left: 16px;
    z-index: 200;
    padding: 12px 24px;
    background: var(--gold-mid);
    color: var(--night);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    border-radius: 0 0 10px 10px;
    transition: top 0.2s ease;
  }

  .skip-link:focus {
    top: 0;
  }

  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 20px 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: box-shadow 0.25s ease, border-color 0.25s ease;
    background: var(--parchment);
    border-bottom: 1px solid transparent;
    box-shadow: 0 1px 8px transparent;
  }

  .nav.scrolled {
    border-bottom-color: rgba(26, 26, 24, 0.06);
    box-shadow: 0 1px 8px rgba(26, 26, 24, 0.04);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 1080px;
    margin: 0 auto;
  }

  .nav__logo {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .nav__wordmark {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 700;
    letter-spacing: 4px;
    color: var(--ink);
  }

  .nav__v {
    color: var(--gold-mid);
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .nav__link {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.5px;
    color: var(--ink-muted);
    transition: color 0.2s ease;
    white-space: nowrap;
    position: relative;
  }

  .nav__link:hover {
    color: var(--ink);
  }

  .nav__link.active {
    color: var(--ink);
    font-weight: 500;
  }

  .nav__link.active::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--gold-mid);
    border-radius: 1px;
  }

  .nav__actions { display: flex; align-items: center; gap: 8px; }

  @media (max-width: 1080px) {
    .nav__waitlist-btn { display: none; }
  }

  .nav__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav__toggle span {
    width: 22px;
    height: 2px;
    background: var(--ink);
    transition: all 0.3s ease;
  }

  @media (max-width: 960px) {
    .nav { padding: 16px 24px; }
    .nav__links {
      position: fixed;
      top: var(--nav-height);
      left: 0;
      right: 0;
      bottom: 0;
      background: var(--parchment);
      flex-direction: column;
      justify-content: center;
      gap: 32px;
      transform: translateX(100%);
      transition: transform 0.4s ease;
    }
    .nav__links.open { transform: translateX(0); }
    .nav__links .nav__link { font-size: 18px; }
    .nav__links .nav__link.active::after { display: none; }
    .nav__toggle { display: flex; }
    .nav__actions { margin-left: auto; margin-right: 12px; }
  }
</style>

<script is:inline>
  (function() {
    var nav = document.getElementById('mainNav');
    if (!nav) return;

    // Hysteresis prevents flicker at the threshold: add at 40px, remove at 10px
    var ENTER_SCROLLED = 40;
    var EXIT_SCROLLED = 10;
    var isScrolled = false;
    var ticking = false;

    function updateNav() {
      var y = window.scrollY;
      if (!isScrolled && y > ENTER_SCROLLED) {
        nav.classList.add('scrolled');
        isScrolled = true;
      } else if (isScrolled && y < EXIT_SCROLLED) {
        nav.classList.remove('scrolled');
        isScrolled = false;
      }
      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        window.requestAnimationFrame(updateNav);
        ticking = true;
      }
    }

    // Set initial state (important for page loads that aren't at top, e.g. anchor links)
    updateNav();
    window.addEventListener('scroll', onScroll, { passive: true });

    var toggle = document.getElementById('navToggle');
    var links = document.getElementById('navLinks');
    if (toggle && links) {
      toggle.addEventListener('click', function() {
        links.classList.toggle('open');
      });
    }
  })();
</script>
