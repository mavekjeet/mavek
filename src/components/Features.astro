---
interface Props {
  dark?: boolean;
}
const { dark = false } = Astro.props;

const features = [
  {
    icon: "paid-ads",
    title: "Paid Ads Management",
    description: "Google, Meta, LinkedIn. Autonomous campaign optimization. Mavek manages budgets, rotates creative, and optimizes bids in real-time.",
  },
  {
    icon: "seo",
    title: "SEO & Content",
    description: "Keyword strategy, content creation, technical SEO. Mavek writes, publishes, and ranks content that drives organic growth.",
  },
  {
    icon: "outreach",
    title: "Outreach & CRM",
    description: "Lead generation, email sequences, pipeline management. Mavek finds prospects, writes personalized outreach, and nurtures leads.",
  },
  {
    icon: "analytics",
    title: "Analytics Dashboard",
    description: "Unified metrics across all channels. Real-time performance data, attribution modeling, and actionable insights in one view.",
  },
  {
    icon: "memory",
    title: "Memory Layer",
    description: "Mavek learns your brand voice, audience patterns, and what converts. Every decision gets smarter over time, compounding results.",
  },
  {
    icon: "approval",
    title: "Approval Gates",
    description: "Human-in-the-loop by default. Nothing goes live without your sign-off. Set auto-approve for trusted workflows when ready.",
  },
];
---

<section class:list={["features", dark ? "dark" : "light"]}>
  <div class="container">
    <div class="features__header reveal">
      <span class="sec-label">Capabilities</span>
      <h2>Everything a marketing team does</h2>
      <p>Six capabilities. One platform. Zero hand-holding.</p>
    </div>
    <div class="features__grid grid-3">
      {features.map((f, i) => (
        <div class="card feature-card reveal" style={`transition-delay: ${i * 0.08}s`}>
          <span class="feature-card__icon">
            {f.icon === "paid-ads" && <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 3l-4 4-4-4"/><line x1="12" y1="11" x2="12" y2="17"/><line x1="9" y1="14" x2="15" y2="14"/></svg>}
            {f.icon === "seo" && <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/><line x1="11" y1="8" x2="11" y2="14"/></svg>}
            {f.icon === "outreach" && <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13"/><path d="M22 2L15 22l-4-9-9-4z"/></svg>}
            {f.icon === "analytics" && <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>}
            {f.icon === "memory" && <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 014 4c0 1.95-1.4 3.58-3.25 3.93"/><path d="M12 2a4 4 0 00-4 4c0 1.95 1.4 3.58 3.25 3.93"/><path d="M12 10v4"/><circle cx="12" cy="18" r="4"/><path d="M9.5 16.5l2.5 2 2.5-2"/></svg>}
            {f.icon === "approval" && <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M9 12l2 2 4-4"/></svg>}
          </span>
          <h4 class="feature-card__title">{f.title}</h4>
          <p class="feature-card__desc">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features__header {
    text-align: center;
    margin-bottom: var(--space-xl);
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .features__header h2 {
    margin-top: var(--space-xs);
    margin-bottom: var(--space-xs);
    font-family: var(--font-display);
    font-weight: 400;
  }

  .features__header p {
    color: var(--ink-soft);
  }

  .dark .features__header p {
    color: var(--cream-60);
  }

  .sec-label {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 4px;
    text-transform: uppercase;
  }

  .light .sec-label {
    color: var(--gold-dark);
  }

  .dark .sec-label {
    color: var(--gold-mid);
  }

  .feature-card {
    border-radius: 10px;
  }

  .light .feature-card {
    background: var(--surface);
  }

  .dark .feature-card {
    background: var(--night-3);
  }

  .feature-card__icon {
    display: block;
    margin-bottom: var(--space-sm);
    line-height: 0;
  }

  .light .feature-card__icon {
    color: var(--gold-dark);
  }

  .dark .feature-card__icon {
    color: var(--gold-mid);
  }

  .feature-card__title {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1.05rem;
    margin-bottom: var(--space-xs);
  }

  .dark .feature-card__title {
    color: var(--cream);
  }

  .feature-card__desc {
    font-size: 14px;
    line-height: 1.6;
  }

  .light .feature-card__desc {
    color: var(--ink-muted);
  }

  .dark .feature-card__desc {
    color: var(--cream-40);
  }
</style>
