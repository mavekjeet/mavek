---
interface Props {
  dark?: boolean;
}
const { dark = false } = Astro.props;

const rows = [
  {
    category: "Point-tool AI",
    examples: "Jasper, Copy.ai",
    they: "One task, no strategy. Generic output.",
    mavek: "Full-funnel strategy grounded in your real data",
  },
  {
    category: "DIY with tools",
    examples: "Google Ads + Meta + GA + Spreadsheets",
    they: "Five logins, no unified view, things slip",
    mavek: "One platform. Cross-channel insights. Everything created for you.",
  },
  {
    category: "Hiring a team",
    examples: "2-5 FTEs across channels",
    they: "$15k+/mo in salaries. Months to ramp up.",
    mavek: "Full marketing team output from day one. Under $500/mo.",
  },
  {
    category: "AI Copilots",
    examples: "ChatGPT, Claude, Gemini",
    they: "Waits for your prompt. No context. No data.",
    mavek: "Already knows your brand, reads your data, creates ready-to-publish assets",
  },
];
---

<section class:list={["diff", dark ? "dark" : "light"]}>
  <div class="container">
    <div class="diff__header reveal">
      <span class="sec-label">Comparison</span>
      <h2>Not another <em>AI tool</em></h2>
    </div>
    <div class="diff__table-wrap reveal">
      <table class="diff__table">
        <thead>
          <tr>
            <th>Category</th>
            <th>They</th>
            <th class="diff__mavek-col">Mavek</th>
          </tr>
        </thead>
        <tbody>
          {rows.map(row => (
            <tr>
              <td>
                <strong>{row.category}</strong>
                <span class="diff__examples">{row.examples}</span>
              </td>
              <td class="diff__they">{row.they}</td>
              <td class="diff__mavek">{row.mavek}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .diff__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .diff__header h2 {
    margin-top: var(--space-xs);
    font-family: var(--font-display);
    font-weight: 400;
  }

  .diff__header h2 em {
    font-style: italic;
  }

  .light .diff__header h2 em {
    color: var(--gold-dark);
  }

  .dark .diff__header h2 em {
    color: var(--gold-bright);
  }

  .sec-label {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 4px;
    text-transform: uppercase;
  }

  .light .sec-label {
    color: var(--gold-dark);
  }

  .dark .sec-label {
    color: var(--gold-mid);
  }

  .diff__table-wrap {
    overflow-x: auto;
  }

  .diff__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .diff__table th {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 3px;
    text-align: left;
    padding: var(--space-sm) var(--space-md);
    border-bottom: 2px solid rgba(26,26,24,0.1);
    color: var(--ink-muted);
  }

  .dark .diff__table th {
    border-bottom-color: rgba(255,255,255,0.08);
    color: var(--cream-40);
  }

  .diff__mavek-col {
    color: var(--gold-dark) !important;
  }

  .dark .diff__mavek-col {
    color: var(--gold-mid) !important;
  }

  .diff__table td {
    padding: var(--space-md);
    border-bottom: 1px solid rgba(26,26,24,0.06);
    vertical-align: top;
  }

  .dark .diff__table td {
    border-bottom-color: rgba(255,255,255,0.06);
    color: var(--cream-60);
  }

  .diff__table td strong {
    display: block;
    margin-bottom: 0.15rem;
  }

  .dark .diff__table td strong {
    color: var(--cream);
  }

  .diff__examples {
    font-family: var(--font-body);
    font-size: 11px;
    color: var(--ink-muted);
  }

  .dark .diff__examples {
    color: var(--cream-40);
  }

  .diff__they {
    color: var(--ink-muted);
  }

  .diff__mavek {
    color: var(--ink);
    font-weight: 500;
  }

  .dark .diff__mavek {
    color: var(--gold-mid);
  }

  @media (max-width: 600px) {
    .diff__table { font-size: 0.8rem; }
    .diff__table td, .diff__table th { padding: var(--space-sm); }
  }
</style>
