---

<footer class="footer dark">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <div class="footer__logo">
          <span class="footer__logo-box" aria-hidden="true">
            <svg width="20" height="28" viewBox="0 0 20 28">
              <!-- Stone in parchment box (light bg rules): S=8, stone-h=16, gap=3.52, rx=6.8 -->
              <ellipse cx="10" cy="21.12" rx="6.8" ry="1.5" fill="#1A1A18" opacity="0.07"/>
              <g transform="translate(10, 8)">
                <path d="M-8 0 L-3.6 -6.4 L0 -6.4 L0 0 Z" fill="#E8C95A"/>
                <path d="M0 -6.4 L3.6 -6.4 L8 0 L0 0 Z" fill="#8A7028"/>
                <path d="M-8 0 L0 0 L0 9.6 Z" fill="#33302A"/>
                <path d="M0 0 L8 0 L0 9.6 Z" fill="#0A0A08"/>
              </g>
            </svg>
          </span>
          <span class="footer__wordmark">MA<span class="footer__v">V</span>EK</span>
        </div>
        <p class="footer__tagline">One person with Mavek does the work of ten.</p>
        <div class="footer__social">
          <a href="https://instagram.com/mavek.ai" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href="https://x.com/mavekAI" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://www.linkedin.com/company/mavek-ai/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
        </div>
      </div>

      <div class="footer__col">
        <h4>Product</h4>
        <a href="/for-agencies">For Agencies</a>
        <a href="/for-brands">For Brands</a>
        <a href="/services">Services</a>
        <a href="/how-it-works">How It Works</a>
        <a href="/pricing">Pricing</a>
        <a href="/compare">Compare</a>
        <a href="/integrations">Integrations</a>
      </div>

      <div class="footer__col">
        <h4>Resources</h4>
        <a href="/tools">Free Tools</a>
        <a href="/use-cases">Use Cases</a>
        <a href="/industries">Industries</a>
        <a href="/glossary">Glossary</a>
        <a href="/blog">Blog</a>
        <a href="/case-studies">Case Studies</a>
      </div>

      <div class="footer__col">
        <h4>Company</h4>
        <a href="/about">About</a>
        <a href="/changelog">Changelog</a>
        <a href="/contact">Contact</a>
        <a href="/sitemap">Sitemap</a>
      </div>
    </div>

    <div class="footer__bottom">
      <p>&copy; 2026 Mavek. All rights reserved.</p>
      <div class="footer__legal">
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
        <a href="/refund-policy">Refund Policy</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 100px 0 40px;
  }

  .footer__logo {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }

  .footer__logo-box {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: var(--parchment);
    border-radius: 8px;
    flex-shrink: 0;
  }

  .footer__logo-box svg {
    width: 16px;
    height: 22px;
  }

  .footer__v {
    color: var(--gold-bright);
  }

  .footer__wordmark {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 4px;
    color: var(--cream);
  }

  .footer__tagline {
    font-size: 13px;
    color: var(--cream-40);
    max-width: 260px;
    line-height: 1.5;
  }

  .footer__social {
    display: flex;
    gap: 12px;
    margin-top: 16px;
  }

  .footer__social a {
    color: var(--cream-40);
    transition: color 0.2s ease;
  }

  .footer__social a:hover { color: var(--gold-mid); }

  .footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 80px;
  }

  .footer__col h4 {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--cream-40);
    margin-bottom: 16px;
  }

  .footer__col a {
    display: block;
    font-size: 12px;
    letter-spacing: 0.5px;
    color: var(--cream-40);
    padding: 4px 0;
    transition: color 0.2s ease;
  }

  .footer__col a:hover { color: var(--gold-mid); }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 32px;
    border-top: 1px solid rgba(201, 168, 76, 0.08);
  }

  .footer__bottom p {
    font-size: 11px;
    letter-spacing: 1px;
    color: var(--cream-25);
  }

  .footer__legal {
    display: flex;
    gap: 24px;
  }

  .footer__legal a {
    font-size: 11px;
    letter-spacing: 1px;
    color: var(--cream-25);
    transition: color 0.2s ease;
  }

  .footer__legal a:hover { color: var(--cream-60); }

  @media (max-width: 768px) {
    .footer__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
    }
    .footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .footer__grid { grid-template-columns: 1fr 1fr; gap: 24px; }
    .footer__brand { grid-column: 1 / -1; }
    .footer__bottom { flex-direction: column; gap: 12px; text-align: center; }
  }
</style>
