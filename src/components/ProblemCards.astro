---
interface Props {
  dark?: boolean;
}
const { dark = true } = Astro.props;

const problems = [
  {
    icon: "01",
    title: "AI tools produce generic slop",
    description: "You've tried ChatGPT, Jasper, and a dozen others. The output sounds like everyone else's. It's not grounded in your data — so you spend hours editing it into something usable.",
  },
  {
    icon: "02",
    title: "Every tool needs hand-holding",
    description: "Nothing runs on its own. You're logging into five platforms daily, copying data between spreadsheets, and context-switching so much that nothing gets done deeply.",
  },
  {
    icon: "03",
    title: "You're doing ten jobs at once",
    description: "Ads, SEO, content, email, analytics, reporting. You know what needs to happen — you just don't have the bandwidth to do it all well. Something always falls through the cracks.",
  },
];
---

<section class:list={["problems", dark ? "dark" : "light"]}>
  <div class="container">
    <div class="problems__header reveal">
      <span class="sec-label">The Problem</span>
      <h2>Sound familiar?</h2>
    </div>
    <div class="problems__grid grid-3">
      {problems.map((p, i) => (
        <div class:list={["problem-card", "reveal", dark && "problem-card--dark"]} style={`transition-delay: ${i * 0.1}s`}>
          <span class="card__number">{p.icon}</span>
          <h4 class="card__title">{p.title}</h4>
          <p class="card__desc">{p.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .problems__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .problems__header h2 {
    margin-top: var(--space-xs);
    font-family: var(--font-display);
    font-weight: 400;
  }

  .sec-label {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 4px;
    text-transform: uppercase;
  }

  .light .sec-label {
    color: var(--gold-dark);
  }

  .dark .sec-label {
    color: var(--gold-mid);
  }

  .problem-card {
    border-radius: 10px;
    padding: 32px;
    background: var(--surface);
    border: 1px solid rgba(26,26,24,0.06);
    transition: transform 0.2s, border-color 0.3s;
  }

  .problem-card:hover {
    transform: translateY(-3px);
  }

  .problem-card--dark {
    background: var(--night-3) !important;
    border-color: rgba(201, 168, 76, 0.1);
  }

  .problem-card--dark:hover {
    border-color: rgba(201, 168, 76, 0.2);
  }

  .card__number {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 3px;
    display: block;
    margin-bottom: var(--space-sm);
  }

  .light .card__number {
    color: var(--gold-dark);
  }

  .dark .card__number {
    color: var(--gold-mid);
  }

  .card__title {
    margin-bottom: var(--space-xs);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.15rem;
  }

  .dark .card__title {
    color: var(--cream);
  }

  .card__desc {
    font-size: 14px;
    line-height: 1.6;
  }

  .light .card__desc {
    color: var(--ink-muted);
  }

  .dark .card__desc {
    color: var(--cream-60);
  }
</style>
