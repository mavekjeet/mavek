---
// Auto-generates BreadcrumbList JSON-LD schema from the current URL path.
// Rendered in Layout.astro so every page gets breadcrumbs automatically.

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

// Known section labels (slug → display name)
const sectionLabels: Record<string, string> = {
  'tools': 'Free Tools',
  'blog': 'Blog',
  'glossary': 'Glossary',
  'compare': 'Compare',
  'industries': 'Industries',
  'use-cases': 'Use Cases',
  'services': 'Services',
  'integrations': 'Integrations',
  'for-agencies': 'For Agencies',
  'for-brands': 'For Brands',
};

// Words that should stay uppercase
const upperWords = new Set([
  'seo', 'ai', 'roi', 'cac', 'clv', 'utm', 'html', 'xml', 'api',
  'serp', 'roas', 'cpc', 'ppc', 'og', 'aeo', 'saas', 'mql',
]);

function slugToTitle(slug: string): string {
  // Check known labels first
  if (sectionLabels[slug]) return sectionLabels[slug];

  return slug
    .split('-')
    .map(word => {
      if (upperWords.has(word)) return word.toUpperCase();
      return word.charAt(0).toUpperCase() + word.slice(1);
    })
    .join(' ');
}

// Build breadcrumb items
const segments = pathname === '/' ? [] : pathname.split('/').filter(Boolean);
const items = [{ name: 'Home', url: 'https://mavek.ai/' }];

for (let i = 0; i < segments.length; i++) {
  const url = 'https://mavek.ai/' + segments.slice(0, i + 1).join('/') + '/';
  const name = slugToTitle(segments[i]);
  items.push({ name, url });
}

// Only render if we have more than just Home
const shouldRender = items.length > 1;

const breadcrumbSchema = shouldRender ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": items.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.name,
    "item": item.url,
  })),
} : null;
---

{breadcrumbSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
)}
